case "${1:-}" in
    start)
        start_recording "${@:2}"
        ;;
    stop)
        stop_recording "${2:-}"
        ;;
    status)
        show_status
        ;;
    setup)
        setup_apps
        ;;
    setup-zoom)
        setup_zoom
        ;;
    setup-teams)
        setup_teams
        ;;
    setup-wemeet)
        setup_wemeet
        ;;
    config)
        case "${2:-edit}" in
            show)
                _t CONFIG_HEADER "$VERSION"
                _t CONFIG_SEPARATOR
                if [[ -f "$CONFIG_FILE" ]]; then
                    _t CONFIG_FILE_PATH "$CONFIG_FILE"
                else
                    _t CONFIG_FILE_NONE
                fi
                echo ""
                # 配置列表用 ui_card 渲染（无 gum 时逐行原样打印，内容不变）
                ui_card \
                    "  region                = $CFG_REGION" \
                    "  language              = $CFG_LANGUAGE" \
                    "  ai_backend            = $CFG_AI_BACKEND" \
                    "  model                 = $CFG_MODEL" \
                    "  transcribe_languages  = $CFG_TRANSCRIBE_LANGUAGES" \
                    "  recording_dir         = $CFG_RECORDING_DIR" \
                    "  max_speakers          = $CFG_MAX_SPEAKERS" \
                    "  silence_threshold     = $CFG_SILENCE_THRESHOLD" \
                    "  silence_grace         = $CFG_SILENCE_GRACE" \
                    "  audio_bitrate         = $CFG_AUDIO_BITRATE" \
                    "  audio_persist         = $CFG_AUDIO_PERSIST" \
                    "  multi_language        = $CFG_MULTI_LANGUAGE" \
                    "  visualizer            = $CFG_VISUALIZER" \
                    "  email                 = ${CFG_EMAIL:-<not set>}" \
                    "  email_sender          = ${CFG_EMAIL_SENDER:-<not set>}"
                echo ""
                [[ -f "$CONFIG_FILE" ]] && _t CONFIG_RESET_HINT "$CONFIG_FILE"
                ;;
            edit|"")
                # ensure_config already created the file at startup if possible;
                # if it's still missing (no template found), try once more or bail.
                if [[ ! -f "$CONFIG_FILE" ]]; then
                    ensure_config
                    [[ -f "$CONFIG_FILE" ]] || {
                        _t CONFIG_NO_TEMPLATE
                        exit 1
                    }
                fi
                MEETAP_EDITOR="${VISUAL:-${EDITOR:-vi}}"
                _t CONFIG_OPENING_EDITOR "$MEETAP_EDITOR"
                exec "$MEETAP_EDITOR" "$CONFIG_FILE"
                ;;
            *)
                echo "Usage: meetap config [edit|show]" >&2
                exit 1
                ;;
        esac
        ;;
    -v|--version|version)
        _t VERSION_LINE "$VERSION"
        ;;
    *)
        _t USAGE_HEADER "$VERSION"
        echo ""
        _t USAGE_LINE
        echo ""
        _t USAGE_START
        _t USAGE_STOP
        _t USAGE_STATUS
        _t USAGE_SETUP
        _t USAGE_CONFIG
        _t USAGE_CONFIG_SHOW
        _t USAGE_VERSION
        echo ""
        _t USAGE_HINT
        ;;
esac
