    echo "   ⚠️  只需设置一次"
    echo ""
    read -p "   设置完成后按 Enter 继续..."
    echo "✅ 腾讯会议设置完成"
}

setup_apps() {
    echo "==============================="
    echo " 会议 App 扬声器一键配置"
    echo "==============================="
