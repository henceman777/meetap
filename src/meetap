#!/bin/bash
# MeeTap - macOS 会议录制 + 自动转录工具
VERSION="1.0.0"

# --- Config ---
CONFIG_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/meetap/config"

# Defaults
CFG_REGION="us-east-1"
CFG_LANGUAGE="zh-CN"
CFG_MODEL="global.anthropic.claude-sonnet-5"
CFG_TRANSCRIBE_LANGUAGES="en-US zh-CN ja-JP"
CFG_RECORDING_DIR="$HOME/Record"
CFG_MAX_SPEAKERS=10
CFG_SILENCE_THRESHOLD=-50
CFG_SILENCE_GRACE=120
CFG_AUDIO_BITRATE="128k"
CFG_MULTI_LANGUAGE=false
CFG_AI_BACKEND="bedrock"
CFG_VISUALIZER="dot"
CFG_AUDIO_PERSIST=true
CFG_AUDIO_CAPTURE="auto"
CFG_EMAIL=""
CFG_EMAIL_SENDER=""

SCRIPT_DIR="$(cd "$(dirname "$0")" && cd "$(dirname "$(readlink "$(basename "$0")" || echo "$(basename "$0")")")" && pwd)"

# Locate the config.default template across install layouts.
# Echoes the path on stdout if found; returns 1 otherwise.
find_config_template() {
    local candidates=(
        "$SCRIPT_DIR/../config.default"               # dev / source tree
        "$SCRIPT_DIR/share/meetap/config.default"     # make install (PREFIX=~/bin)
        "$SCRIPT_DIR/../share/meetap/config.default"  # make install (standard prefix)
        "/opt/homebrew/etc/meetap/config.default"     # Homebrew (Apple Silicon)
        "/usr/local/etc/meetap/config.default"        # Homebrew (Intel)
    )
    for p in "${candidates[@]}"; do
        [[ -f "$p" ]] && { echo "$p"; return 0; }
    done
    return 1
}

# On first run, copy the default config into XDG_CONFIG_HOME so the tool
# works out of the box regardless of install method (make, brew, etc.).
ensure_config() {
    [[ -f "$CONFIG_FILE" ]] && return 0
    local template
    template=$(find_config_template) || return 0   # template missing → silently fall back to built-in defaults
    mkdir -p "$(dirname "$CONFIG_FILE")" || return 0
    cp "$template" "$CONFIG_FILE" 2>/dev/null || return 0
    # i18n is not yet loaded here — emit a neutral hint using the locale fallback.
    # The first-run message is printed to stderr so it doesn't pollute piped stdout.
    echo "📝 Default config created: $CONFIG_FILE" >&2
}

load_config() {
    [[ -f "$CONFIG_FILE" ]] || return 0
    while IFS= read -r line; do
        line="${line%%#*}"
        line="${line#"${line%%[![:space:]]*}"}"
        line="${line%"${line##*[![:space:]]}"}"
        [[ -z "$line" ]] && continue
        local key="${line%%=*}"
        local val="${line#*=}"
        key="${key#"${key%%[![:space:]]*}"}"
        key="${key%"${key##*[![:space:]]}"}"
        val="${val#"${val%%[![:space:]]*}"}"
        val="${val%"${val##*[![:space:]]}"}"
        case "$key" in
            region)                CFG_REGION="$val" ;;
            language)              CFG_LANGUAGE="$val" ;;
            model)                 CFG_MODEL="$val" ;;
            transcribe_languages)  CFG_TRANSCRIBE_LANGUAGES="$val" ;;
            recording_dir)         CFG_RECORDING_DIR="${val/#\~/$HOME}" ;;
            max_speakers)          CFG_MAX_SPEAKERS="$val" ;;
            silence_threshold)     CFG_SILENCE_THRESHOLD="$val" ;;
            silence_grace)         CFG_SILENCE_GRACE="$val" ;;
            audio_bitrate)         CFG_AUDIO_BITRATE="$val" ;;
            multi_language)        CFG_MULTI_LANGUAGE="$val" ;;
            ai_backend)            CFG_AI_BACKEND="$val" ;;
            visualizer)            CFG_VISUALIZER="$val" ;;
            audio_persist)         CFG_AUDIO_PERSIST="$val" ;;
            audio_capture)         CFG_AUDIO_CAPTURE="$val" ;;
            email)                 CFG_EMAIL="$val" ;;
            email_sender)          CFG_EMAIL_SENDER="$val" ;;
        esac
    done < "$CONFIG_FILE"
}

ensure_config
load_config

# --- i18n (CLI display only; meeting notes are always Chinese) ---
load_i18n() {
    local i18n_dir=""
    # Look for i18n/ across dev, make install, and Homebrew layouts
    for d in \
        "$SCRIPT_DIR/i18n" \
        "$SCRIPT_DIR/../src/i18n" \
        "$SCRIPT_DIR/../share/meetap/i18n" \
        "/opt/homebrew/share/meetap/i18n" \
        "/usr/local/share/meetap/i18n"; do
        [[ -d "$d" ]] && { i18n_dir="$d"; break; }
    done
    [[ -z "$i18n_dir" ]] && return 0

    local lang="${CFG_LANGUAGE:-zh-CN}"
    local msg_file="$i18n_dir/messages-${lang}.sh"
    [[ -f "$msg_file" ]] || msg_file="$i18n_dir/messages-zh-CN.sh"
    [[ -f "$msg_file" ]] && source "$msg_file"
}

# _t KEY [args...]  →  look up MSG_<KEY> and print with trailing newline
_t() {
    local key="MSG_$1"; shift
    local template="${!key}"
    [[ -z "$template" ]] && template="<missing:${key#MSG_}>"
    # shellcheck disable=SC2059
    printf -- "$template\n" "$@"   # `--` 防模板以 - 开头（如 "---" 分隔线）被当成选项
}

# _tn KEY [args...]  →  like _t but without trailing newline (for embedding)
_tn() {
    local key="MSG_$1"; shift
    local template="${!key}"
    [[ -z "$template" ]] && template="<missing:${key#MSG_}>"
    # shellcheck disable=SC2059
    printf -- "$template" "$@"
}

load_i18n

# --- UI 抽象层（gum 可选依赖；无 gum / 无 TTY 时自动降级为纯文本）---
for _ui_path in "$SCRIPT_DIR/lib/ui.sh" "$SCRIPT_DIR/../src/lib/ui.sh"; do
    [[ -f "$_ui_path" ]] && { source "$_ui_path"; break; }
done
unset _ui_path
# 兜底：ui.sh 缺失时提供纯文本实现，保证脚本可用
if ! declare -F ui_confirm >/dev/null; then
    ui_confirm() {
        local prompt="${1:-确认?}" yn=""
        IFS= read -rp "$prompt [y/N]: " yn || yn=""
        [[ "$yn" =~ ^[Yy] ]]
    }
    ui_card() { printf '%s\n' "$@"; }
    ui_pause() {
        local _discard
        IFS= read -rp "${1:-按 Enter 继续...}" _discard || true
        return 0
    }
fi

TOOL="$SCRIPT_DIR/audio-multi-output"
MONITOR="$SCRIPT_DIR/audio-monitor"
VENV_PYTHON="$SCRIPT_DIR/meetap-venv/bin/python3"
RECORDING_DIR="$CFG_RECORDING_DIR"
STATE_DIR="/tmp/meeting-record"

mkdir -p "$RECORDING_DIR" "$STATE_DIR"

# 状态文件
PID_FILE="$STATE_DIR/ffmpeg.pid"
MONITOR_PID_FILE="$STATE_DIR/monitor.pid"
ORIGINAL_UID_FILE="$STATE_DIR/original-output.uid"
ORIGINAL_NAME_FILE="$STATE_DIR/original-output.name"
OUTPUT_FILE_MARKER="$STATE_DIR/output-file"
AUTOSTOP_PID_FILE="$STATE_DIR/autostop.pid"
MEETING_APPS_FILE="$STATE_DIR/meeting-apps"
VISUALIZER_PID_FILE="$STATE_DIR/visualizer.pid"

KNOWN_MEETING_APPS="zoom.us|Microsoft Teams|TencentMeeting|Webex|Lark|Feishu|DingTalk|Slack"

detect_meeting_apps() {
    local found=""
    while IFS= read -r proc; do
        [[ -n "$proc" ]] && found="${found:+$found,}$proc"
    done < <(ps -eo comm= | grep -oE "$KNOWN_MEETING_APPS" | sort -u)
    echo "$found"
}

setup_statusbar() {
    local tty_dev="$1"
    local rows
    rows=$(tput lines 2>/dev/null < "$tty_dev" || echo 24)
    printf '\033[1;%dr' "$((rows - 1))" > "$tty_dev"
    printf '\033[%d;1H\033[K' "$rows" > "$tty_dev"
    printf '\033[%d;1H' "$((rows - 1))" > "$tty_dev"
}

teardown_statusbar() {
    local tty_dev="$1"
    local rows
    rows=$(tput lines 2>/dev/null < "$tty_dev" || echo 24)
    printf '\033[1;%dr' "$rows" > "$tty_dev"
    printf '\033[%d;1H\033[K' "$rows" > "$tty_dev"
}

start_visualizer() {
    local tty_dev="$1"
    local style="${CFG_VISUALIZER:-dot}"
    local WIDTH=30
    local history=()
    for ((i=0; i<WIDTH; i++)); do history+=(0); done
    local START_TS=$(date +%s)

    local CHARS
    case "$style" in
        bar)
            CHARS=("▁" "▂" "▃" "▄" "▅" "▆" "▇" "█") ;;
        dot)
            CHARS=("⠀" "⡀" "⡄" "⡆" "⡇" "⣇" "⣷" "⣿") ;;
        block)
            CHARS=(" " "░" "░" "▒" "▒" "▓" "▓" "█") ;;
        spectrum|*)
            CHARS=("▁" "▂" "▃" "▄" "▅" "▆" "▇" "█") ;;
    esac
    local MAX_IDX=$(( ${#CHARS[@]} - 1 ))
    local ROWS
    ROWS=$(tput lines 2>/dev/null < "$tty_dev" || echo 24)

    # 电平来源双模式：tap 模式读 audio-tap --level-file 写的电平文件（0.4s 更新）；
    # BlackHole 模式沿用 ffmpeg 短采样。tap 模式音频不经过 BlackHole，旧方式采不到。
    local LEVEL_FILE="$STATE_DIR/tap-level"
    while kill -0 "$(cat "$PID_FILE" 2>/dev/null)" 2>/dev/null; do
        local max_vol
        if [[ -f "$LEVEL_FILE" ]]; then
            max_vol=$(cat "$LEVEL_FILE" 2>/dev/null)
            sleep 0.4
        else
            max_vol=$(ffmpeg -nostdin -f avfoundation -i ":BlackHole 2ch" -t 0.4 \
                -af volumedetect -f null /dev/null 2>&1 \
                | sed -n 's/.*max_volume: \([-0-9.]*\).*/\1/p')
        fi
        [[ -z "$max_vol" ]] && max_vol="-91"

        local vi=${max_vol%%.*}
        vi=${vi#-}
        local level
        if [[ $vi -ge 80 ]]; then level=0
        elif [[ $vi -le 3 ]]; then level=$MAX_IDX
        else level=$(( (80 - vi) * MAX_IDX / 77 )); fi

        history=("${history[@]:1}" "$level")

        local bar=""
        if [[ "$style" == "spectrum" ]]; then
            for ((i=0; i<WIDTH; i++)); do
                local l=${history[$i]}
                local c
                if [[ $l -le 2 ]]; then   c="\033[32m"
                elif [[ $l -le 4 ]]; then  c="\033[33m"
                elif [[ $l -le 5 ]]; then  c="\033[38;5;208m"
                else                        c="\033[31m"
                fi
                bar="${bar}${c}${CHARS[$l]}\033[0m"
            done
        else
            for ((i=0; i<WIDTH; i++)); do
                bar="${bar}${CHARS[${history[$i]}]}"
            done
        fi

        local now=$(date +%s)
        local secs=$(( now - START_TS ))
        local elapsed=$(printf "%02d:%02d" $((secs/60)) $((secs%60)))

        printf '\0337\033[%d;1H\033[K 🎙️ %b  %s\0338' "$ROWS" "$bar" "$elapsed" > "$tty_dev" 2>/dev/null || break
    done
}

stop_visualizer() {
    if [[ -f "$VISUALIZER_PID_FILE" ]]; then
        kill "$(cat "$VISUALIZER_PID_FILE")" 2>/dev/null
        rm -f "$VISUALIZER_PID_FILE"
    fi
    local tty_dev
    tty_dev=$(tty 2>/dev/null)
    if [[ -n "$tty_dev" && "$tty_dev" != "not a tty" ]]; then
        teardown_statusbar "$tty_dev"
    fi
}

is_audio_silent() {
    local mean_vol
    mean_vol=$(ffmpeg -f avfoundation -i ":BlackHole 2ch" -t 5 \
        -af volumedetect -f null /dev/null 2>&1 \
        | sed -n 's/.*mean_volume: \([-0-9.]*\).*/\1/p')
    if [[ -z "$mean_vol" ]]; then
        return 1
    fi
    local vol_int=${mean_vol%%.*}
    [[ $vol_int -le $CFG_SILENCE_THRESHOLD ]]
}

autostop_daemon() {
    local silence_start=""

    while true; do
        if [[ ! -f "$PID_FILE" ]] || ! kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
            break
        fi

        if is_audio_silent; then
            if [[ -z "$silence_start" ]]; then
                silence_start=$(date +%s)
            fi
            local elapsed=$(( $(date +%s) - silence_start ))
            if [[ $elapsed -ge $CFG_SILENCE_GRACE ]]; then
                osascript -e "display notification \"$(_tn AUTOSTOP_NOTIFY "$CFG_SILENCE_GRACE")\" with title \"MeeTap\"" 2>/dev/null
                "$0" stop
                break
            fi
        else
            silence_start=""
        fi

        sleep 30
    done
}

transcribe_recording() {
    local AUDIO_FILE="$1"
    local SESSION_DIR="$2"
    local LOG_DIR="$SESSION_DIR/log"
    mkdir -p "$LOG_DIR"
    local LOG_FILE="$LOG_DIR/meetap.log"
    local AWS_REGION="$CFG_REGION"

    # 语音文件保留在 session 根目录原位，不再移入 log/（用户要求位置不变动）

    exec > "$LOG_FILE" 2>&1
    echo "[$(date '+%H:%M:%S')] $(_tn TRANSCRIBE_STARTED)"

    if ! command -v aws &>/dev/null; then
        _t ERR_AWS_CLI_MISSING
        return 1
    fi

    local ACCOUNT_ID
    ACCOUNT_ID=$(aws sts get-caller-identity --query Account --output text 2>/dev/null)
    if [[ -z "$ACCOUNT_ID" ]]; then
        _t ERR_AWS_CREDS_MISSING
        return 1
    fi

    # 用 Account ID 短哈希代替明文，避免桶名泄露 AWS 账户 ID（桶名仍全局唯一且稳定）
    local ACCOUNT_HASH
    ACCOUNT_HASH=$(printf '%s' "$ACCOUNT_ID" | shasum -a 256 | cut -c1-12)
    local BUCKET="meetap-transcribe-${ACCOUNT_HASH}-${AWS_REGION}"
    local AUDIO_BASENAME
    AUDIO_BASENAME=$(basename "$AUDIO_FILE")
    local JOB_NAME="meetap-$(date +%Y%m%d-%H%M%S)-$$"

    # Create bucket if not exists
    aws s3 mb "s3://${BUCKET}" --region "$AWS_REGION" 2>/dev/null || true

    # 锁死公共访问，兜底防止误配导致内容泄露
    aws s3api put-public-access-block \
        --bucket "$BUCKET" \
        --public-access-block-configuration \
        BlockPublicAcls=true,IgnorePublicAcls=true,BlockPublicPolicy=true,RestrictPublicBuckets=true \
        --region "$AWS_REGION" 2>/dev/null || true

    # Upload
    echo "[$(date '+%H:%M:%S')] $(_tn UPLOADING)"
    if ! aws s3 cp "$AUDIO_FILE" "s3://${BUCKET}/${AUDIO_BASENAME}" --region "$AWS_REGION"; then
        _t ERR_UPLOAD_FAILED
        return 1
    fi

    if [[ "$CFG_AUDIO_PERSIST" != "true" && ! -f "$STATE_DIR/test-mode" ]]; then
        rm -f "$AUDIO_FILE"
        echo "[$(date '+%H:%M:%S')] $(_tn LOCAL_AUDIO_DELETED)"
    fi

    # Start transcription
    local LANG_FLAG="--identify-language"
    if [[ "$CFG_MULTI_LANGUAGE" == "true" ]]; then
        LANG_FLAG="--identify-multiple-languages"
    fi
    echo "[$(date '+%H:%M:%S')] $(_tn START_JOB "$JOB_NAME")"
    aws transcribe start-transcription-job \
        --transcription-job-name "$JOB_NAME" \
        $LANG_FLAG \
        --language-options $CFG_TRANSCRIBE_LANGUAGES \
        --media-format "mp4" \
        --media "{\"MediaFileUri\": \"s3://${BUCKET}/${AUDIO_BASENAME}\"}" \
        --output-bucket-name "$BUCKET" \
        --region "$AWS_REGION" \
        --settings "{\"ShowSpeakerLabels\": true, \"MaxSpeakerLabels\": $CFG_MAX_SPEAKERS}" \
        > /dev/null

    # Poll for completion
    local POLL_ERRORS=0
    while true; do
        local STATUS
        STATUS=$(aws transcribe get-transcription-job \
            --transcription-job-name "$JOB_NAME" \
            --region "$AWS_REGION" \
            --query 'TranscriptionJob.TranscriptionJobStatus' \
            --output text 2>/dev/null)
        if [[ -z "$STATUS" ]]; then
            POLL_ERRORS=$((POLL_ERRORS + 1))
            echo "[$(date '+%H:%M:%S')] $(_tn STATUS_QUERY_RETRY "$POLL_ERRORS")"
            if [[ $POLL_ERRORS -ge 5 ]]; then
                _t STATUS_QUERY_ABORT
                break
            fi
            sleep 10
            continue
        fi
        POLL_ERRORS=0
        echo "[$(date '+%H:%M:%S')] $(_tn STATUS_LINE "$STATUS")"
        [[ "$STATUS" != "IN_PROGRESS" ]] && break
        sleep 10
    done

    if [[ "$STATUS" != "COMPLETED" ]]; then
        local REASON
        REASON=$(aws transcribe get-transcription-job \
            --transcription-job-name "$JOB_NAME" \
            --region "$AWS_REGION" \
            --query 'TranscriptionJob.FailureReason' \
            --output text 2>/dev/null)
        _t ERR_TRANSCRIBE_FAILED "${STATUS:-empty} ${REASON:+— $REASON}"
        aws s3 rm "s3://${BUCKET}" --recursive --region "$AWS_REGION" 2>/dev/null
        aws transcribe delete-transcription-job --transcription-job-name "$JOB_NAME" --region "$AWS_REGION" 2>/dev/null
        osascript -e "display notification \"$(_tn NOTIFY_TRANSCRIBE_FAILED)\" with title \"MeeTap\"" 2>/dev/null
        return 1
    fi

    # Download result
    echo "[$(date '+%H:%M:%S')] $(_tn DOWNLOADING)"
    aws s3 cp "s3://${BUCKET}/${JOB_NAME}.json" "$LOG_DIR/transcribe-raw.json" --region "$AWS_REGION"

    # Extract transcript with speaker labels
    python3 - "$SESSION_DIR" <<'PYEOF'
import json, sys, os

session_dir = sys.argv[1]
log_dir = os.path.join(session_dir, "log")
raw_json = os.path.join(log_dir, "transcribe-raw.json")
output_txt = os.path.join(log_dir, "transcript.txt")

with open(raw_json) as f:
    data = json.load(f)

items = data["results"]["items"]
segments = data["results"]["speaker_labels"]["segments"]

time_speaker = {}
for seg in segments:
    for si in seg["items"]:
        time_speaker[si["start_time"]] = si["speaker_label"]

lines = []
current_speaker = None
current_words = []

for item in items:
    if item["type"] == "pronunciation":
        speaker = time_speaker.get(item["start_time"], current_speaker)
        word = item["alternatives"][0]["content"]
        if speaker != current_speaker:
            if current_speaker and current_words:
                lines.append(f"{current_speaker}: {' '.join(current_words)}")
            current_speaker = speaker
            current_words = []
        current_words.append(word)
    elif item["type"] == "punctuation":
        if current_words:
            current_words[-1] += item["alternatives"][0]["content"]

if current_speaker and current_words:
    lines.append(f"{current_speaker}: {' '.join(current_words)}")

with open(output_txt, "w") as f:
    f.write("\n\n".join(lines) + "\n")

print(f"Transcript saved: {len(lines)} speaker turns")
PYEOF

    # Cleanup S3 bucket and Transcribe job
    aws s3 rm "s3://${BUCKET}" --recursive --region "$AWS_REGION" 2>/dev/null
    aws transcribe delete-transcription-job --transcription-job-name "$JOB_NAME" --region "$AWS_REGION" 2>/dev/null

    # Extract speaker stats from raw JSON
    python3 - "$SESSION_DIR" <<'PYEOF'
import json, sys, os
session_dir = sys.argv[1]
log_dir = os.path.join(session_dir, "log")
raw_json = os.path.join(log_dir, "transcribe-raw.json")
stats_file = os.path.join(log_dir, "speaker-stats.txt")
with open(raw_json) as f:
    data = json.load(f)
segments = data["results"]["speaker_labels"]["segments"]
speakers = {}
for seg in segments:
    spk = seg["speaker_label"]
    dur = float(seg["end_time"]) - float(seg["start_time"])
    speakers[spk] = speakers.get(spk, 0) + dur
total = sum(speakers.values())
lines = []
for spk in sorted(speakers):
    dur = speakers[spk]
    m, s = divmod(int(dur), 60)
    pct = dur / total * 100 if total > 0 else 0
    lines.append(f"{spk}: {m}m{s:02d}s ({pct:.1f}%)")
total_m, total_s = divmod(int(total), 60)
lines.append(f"total: {total_m}m{total_s:02d}s")
with open(stats_file, "w") as f:
    f.write("\n".join(lines) + "\n")
print(f"Speaker stats saved: {stats_file}")
PYEOF

    echo "[$(date '+%H:%M:%S')] $(_tn TRANSCRIBE_DONE "$LOG_DIR/transcript.txt")"
    osascript -e "display notification \"$(_tn NOTIFY_TRANSCRIBE_DONE)\" with title \"MeeTap\"" 2>/dev/null

    # Generate meeting notes via Bedrock
    summarize_transcript "$SESSION_DIR"
}

build_prompt() {
    local SESSION_DIR="$1"
    local LOG_DIR="$SESSION_DIR/log"
    local TRANSCRIPT="$LOG_DIR/transcript.txt"
    local SPEAKER_STATS="$LOG_DIR/speaker-stats.txt"
    local SESSION_NAME
    SESSION_NAME=$(basename "$SESSION_DIR")

    local SESSION_DATE
    local folder_base="${SESSION_NAME%%_*}"
    # 取第二段做时间：目录名可能带用户会议名后缀（20250715_1430_季度架构评审），
    # 不能用 ##*_ 取最后一段，先去掉第一段再取剩余的第一段
    local folder_time="${SESSION_NAME#*_}"
    folder_time="${folder_time%%_*}"
    if [[ ${#folder_base} -eq 8 ]]; then
        local y="${folder_base:0:4}" m="${folder_base:4:2}" d="${folder_base:6:2}"
        local weekday
        weekday=$(date -j -f "%Y-%m-%d" "${y}-${m}-${d}" "+%u" 2>/dev/null)
        local weekdays=("" "周一" "周二" "周三" "周四" "周五" "周六" "周日")
        SESSION_DATE="${y}-${m}-${d}（${weekdays[$weekday]}）${folder_time:0:2}:${folder_time:2:2}"
    else
        local m="${folder_base:0:2}" d="${folder_base:2:2}"
        SESSION_DATE="$(date +%Y)-${m}-${d} ${folder_time:0:2}:${folder_time:2:2}"
    fi

    local transcript
    transcript=$(cat "$TRANSCRIPT")
    if [[ ${#transcript} -gt 120000 ]]; then
        transcript="${transcript:0:120000}

[... 内容过长，已截断 ...]"
    fi

    local speaker_stats=""
    [[ -f "$SPEAKER_STATS" ]] && speaker_stats=$(cat "$SPEAKER_STATS")

    # 三级模板查找：会话级 > 用户级 > 默认级（复用 SCRIPT_DIR 的多路径查找）
    # 前两条是 override（用户可编辑的覆盖模板），其余是 default（随工具分发）。
    # 校验失败时按来源决定「警告回退」还是「硬错误」。
    local user_template="${XDG_CONFIG_HOME:-$HOME/.config}/meetap/prompts/meeting-notes.md"
    local candidates=(
        "$SESSION_DIR/prompt.md"                                   # 会话级：本次会议专属
        "$user_template"                                           # 用户级：全局自定义
        "$SCRIPT_DIR/../share/meetap/prompts/meeting-notes.md"    # dev 源码树 / 标准 prefix
        "$SCRIPT_DIR/share/meetap/prompts/meeting-notes.md"       # make install (PREFIX=~/bin)
    )

    # 模板必须包含的三个占位符（缺任何一个都算损坏）
    local required=('${SESSION_DATE}' '${speaker_stats}' '${transcript}')

    local template="" i
    for i in "${!candidates[@]}"; do
        local p="${candidates[$i]}"
        [[ -f "$p" ]] || continue

        # 校验：逐个检查必需占位符是否存在（-F 固定字符串，$ { } 不被当正则）
        local missing="" ph
        for ph in "${required[@]}"; do
            grep -qF "$ph" "$p" || { missing="$ph"; break; }
        done

        if [[ -n "$missing" ]]; then
            # 由索引推导来源：前两条 candidate 是 override，后面的是 default
            local kind
            if [[ $i -lt 2 ]]; then kind=override; else kind=default; fi
            if [[ "$kind" == "override" ]]; then
                # 用户改坏了覆盖模板：警告并继续往后找默认模板
                echo "$(_tn WARN_PROMPT_TEMPLATE_INVALID "$p" "$missing")" >&2
                continue
            else
                # 默认模板损坏：分发出了问题，硬错误
                echo "$(_tn ERR_PROMPT_TEMPLATE_INVALID "$p" "$missing")" >&2
                return 1
            fi
        fi

        template="$p"
        break
    done

    if [[ -z "$template" ]]; then
        echo "$(_tn ERR_PROMPT_TEMPLATE_MISSING)" >&2
        return 1
    fi

    # 变量注入：只替换白名单三个占位符，值来自环境变量，作为纯字面量替换。
    # 用 perl 而非 eval/envsubst——perl 把值当普通字符串写回，
    # transcript 里的 $(...)、反引号、${foo} 等 shell 元字符不会被执行或二次替换。
    # 单次遍历同时替换三者，注入值不会被后续 pass 再次匹配（保持与旧 heredoc 一致的语义）。
    SESSION_DATE="$SESSION_DATE" speaker_stats="$speaker_stats" transcript="$transcript" \
    perl -pe '
        s/\$\{(SESSION_DATE|speaker_stats|transcript)\}/$ENV{$1}/g;
    ' "$template"
}

summarize_via_bedrock() {
    local PROMPT_FILE="$1"
    local OUTPUT="$2"
    local AWS_REGION="$CFG_REGION"
    local MODEL_ID="$CFG_MODEL"

    "$VENV_PYTHON" - "$PROMPT_FILE" "$OUTPUT" "$AWS_REGION" "$MODEL_ID" <<'PYEOF'
import sys, boto3

prompt_path = sys.argv[1]
output_path = sys.argv[2]
region = sys.argv[3]
model_id = sys.argv[4]

with open(prompt_path, "r") as f:
    prompt = f.read()

try:
    client = boto3.client("bedrock-runtime", region_name=region)
    response = client.converse_stream(
        modelId=model_id,
        messages=[{"role": "user", "content": [{"text": prompt}]}],
        inferenceConfig={"maxTokens": 16000},
    )

    text_parts = []
    for event in response["stream"]:
        if "contentBlockDelta" in event:
            delta = event["contentBlockDelta"]["delta"]
            if "text" in delta:
                text_parts.append(delta["text"])

    text = "".join(text_parts)

    if not text.strip():
        print("Error: empty response from Bedrock")
        sys.exit(1)

    with open(output_path, "w") as f:
        f.write(text)

    print(f"Meeting notes saved: {output_path}")

except Exception as e:
    print(f"Error: {e}")
    sys.exit(1)
PYEOF
}

summarize_via_claude_code() {
    local PROMPT_FILE="$1"
    local OUTPUT="$2"

    if ! command -v claude &>/dev/null; then
        echo "[$(date '+%H:%M:%S')] $(_tn CLAUDE_CLI_MISSING_FALLBACK)"
        summarize_via_bedrock "$PROMPT_FILE" "$OUTPUT"
        return
    fi

    claude -p "$(cat "$PROMPT_FILE")" > "$OUTPUT" 2>/dev/null

    if [[ ! -s "$OUTPUT" ]]; then
        echo "[$(date '+%H:%M:%S')] $(_tn CLAUDE_EMPTY_FALLBACK)"
        rm -f "$OUTPUT"
        summarize_via_bedrock "$PROMPT_FILE" "$OUTPUT"
    fi
}

send_meeting_notes() {
    local NOTES_FILE="$1"
    local SESSION_DIR="$2"
    local recipients="$CFG_EMAIL"
    local sender="$CFG_EMAIL_SENDER"

    # venv 缺失：无法做 HTML 转换；仅在用户配了邮件时才报错提示
    if [[ ! -x "$VENV_PYTHON" ]]; then
        [[ -n "$recipients" ]] && echo "[$(date '+%H:%M:%S')] $(_tn ERR_EMAIL_VENV_MISSING)"
        return 1
    fi
    # 配了收件人但缺发件人：提示后降级为只生成 HTML 文件、不发送
    if [[ -n "$recipients" && -z "$sender" ]]; then
        echo "[$(date '+%H:%M:%S')] $(_tn ERR_EMAIL_SENDER_MISSING)"
        recipients=""
    fi

    local PDF_FILE="${NOTES_FILE%.md}.pdf"
    local HTML_FILE="${NOTES_FILE%.md}.html"
    echo "[$(date '+%H:%M:%S')] $(_tn EMAIL_CONVERTING)"

    # SCRIPT_DIR 作为 argv 传入：heredoc 运行时 sys.argv[0] 是 '-'，
    # Python 侧无法自行定位安装目录，必须由 bash 显式传递
    "$VENV_PYTHON" - "$NOTES_FILE" "$PDF_FILE" "$recipients" "$sender" "$CFG_REGION" "$HTML_FILE" "$SCRIPT_DIR" <<'PYEOF'
import sys, os, re, boto3
from email.mime.multipart import MIMEMultipart
from email.mime.text import MIMEText
from email.mime.application import MIMEApplication

notes_path = sys.argv[1]
pdf_path = sys.argv[2]
recipients = [r.strip() for r in sys.argv[3].split(",") if r.strip()]
sender = sys.argv[4]
region = sys.argv[5]
html_path = sys.argv[6]
script_dir = sys.argv[7]   # bash 侧 SCRIPT_DIR：heredoc 下 argv[0] 是 '-'，无法自行定位
html = None

with open(notes_path, "r") as f:
    md_content = f.read()

# Extract title from first H1
title = "Meeting Notes"
for line in md_content.split("\n"):
    if line.startswith("# "):
        title = line[2:].strip()
        break

if html is None:
    # Extract date from metadata block (> **会议时间** ...)
    meeting_date = ""
    for line in md_content.split("\n"):
        m = re.match(r'>\s*\*\*会议时间\*\*\s*(.+)', line)
        if m:
            meeting_date = m.group(1).strip()
            break

    # 邮件版去掉「## 目录」整节（邮件一屏可读不需要跳转目录；md 文件保留）
    md_content = re.sub(r'^## 目录\s*\n.*?(?=^## )', '', md_content, flags=re.MULTILINE | re.DOTALL)
    # 去掉章节间的间距 div，让邮件上下更紧凑（md 文件保留）
    md_content = re.sub(r'^<div style="height:[^"]*"></div>\s*$', '', md_content, flags=re.MULTILINE)

    # --- Markdown to HTML: prefer `markdown` library, fallback to regex ---
    body_html = None
    try:
        import markdown
        body_html = markdown.markdown(md_content, extensions=['tables', 'fenced_code'])
    except ImportError:
        pass

    if body_html is None:
        # Fallback: basic regex conversion (legacy, works without markdown lib)
        body_html = md_content
        body_html = re.sub(r'^# (.+)$', r'<h1>\1</h1>', body_html, flags=re.MULTILINE)
        body_html = re.sub(r'^## (.+)$', r'<h2>\1</h2>', body_html, flags=re.MULTILINE)
        body_html = re.sub(r'^### (.+)$', r'<h3>\1</h3>', body_html, flags=re.MULTILINE)
        body_html = re.sub(r'\[([^\]]+)\]\(([^)]+)\)', r'<a href="\2">\1</a>', body_html)
        body_html = re.sub(r'\*\*(.+?)\*\*', r'<strong>\1</strong>', body_html)
        body_html = re.sub(r'\*(.+?)\*', r'<em>\1</em>', body_html)
        body_html = re.sub(r'^- \[ \] (.+)$', r'<li>☐ \1</li>', body_html, flags=re.MULTILINE)
        body_html = re.sub(r'^- \[x\] (.+)$', r'<li>☑ \1</li>', body_html, flags=re.MULTILINE)
        body_html = re.sub(r'^- (.+)$', r'<li>\1</li>', body_html, flags=re.MULTILINE)
        body_html = re.sub(r'^---$', r'<hr>', body_html, flags=re.MULTILINE)
        body_html = re.sub(r'((?:<li>.*?</li>\n?)+)', r'<ul>\1</ul>', body_html)
        lines = body_html.split('\n')
        out, buf = [], []
        for ln in lines:
            s = ln.strip()
            if not s:
                if buf:
                    block = ' '.join(buf)
                    if not re.match(r'<(h[1-3]|li|ul|/ul|hr|p)', block):
                        out.append(f'<p>{block}</p>')
                    else:
                        out.append(block)
                    buf = []
            else:
                buf.append(ln)
        if buf:
            block = ' '.join(buf)
            if not re.match(r'<(h[1-3]|li|ul|/ul|hr|p)', block):
                out.append(f'<p>{block}</p>')
            else:
                out.append(block)
        body_html = '\n'.join(out)

    # 正文里 Claude 按模板要求写了 LARRY 页脚；模板外框会再注入 footer，
    # 先剥掉正文里的那份，避免邮件出现双页脚；连同落款上方的分割线 <hr> 一起剥
    # （模板 footer 自带浅灰细线，md 的 --- 转成的黑色 <hr> 会重复且突兀）
    body_html = re.sub(r'(<hr\s*/?>\s*)?<p[^>]*>.{0,40}——.{0,200}?[Mm]eetap.{0,200}?——.{0,40}</p>', '', body_html, flags=re.DOTALL)

    # --- Load email template (table layout, email-client compatible) ---
    # 标志性 LARRY 落款，与 md 版一致（首字母大写体现藏头）；nowrap+小字号保证单行
    footer_html = ('<span style="white-space:nowrap;font-size:11px"><em>&mdash;&mdash; '
        'Listen &middot; Analyze &middot; Recap &middot; Refine &middot; Yield &mdash; '
        '<a href="https://github.com/henceman777/meetap" '
        'style="color:#4a90d9;text-decoration:none">Meetap</a> &mdash; '
        'Your Audio Notes Generator &mdash;&mdash;</em></span>')

    # Locate the email.html template relative to the install dir (passed from bash)
    template_candidates = [
        os.path.join(script_dir, "..", "share", "meetap", "templates", "email.html"),
        os.path.join(script_dir, "share", "meetap", "templates", "email.html"),
    ]
    template_html = None
    for tp in template_candidates:
        if os.path.isfile(tp):
            with open(tp, "r") as f:
                template_html = f.read()
            break

    if template_html:
        # Inject into the table-layout template (inline CSS, no <style> tag)
        html = template_html.replace("{{meeting_title}}", title)
        html = html.replace("{{meeting_date}}", meeting_date)
        html = html.replace("{{minutes_body}}", body_html)
        html = html.replace("{{footer}}", footer_html)
    else:
        # Fallback: wrap body_html in a minimal inline-styled container
        html = f"""<!DOCTYPE html>
<html><head><meta charset="utf-8"></head>
<body style="margin:0;padding:20px;font-family:Arial,sans-serif;font-size:14px;color:#333;line-height:1.6">
<div style="max-width:600px;margin:0 auto">{body_html}
<p style="color:#999;font-size:12px;margin-top:24px;text-align:center">{footer_html}</p>
</div></body></html>"""

# 落盘 HTML 版本（无论是否发邮件，都在纪要旁生成 .html 文件）
try:
    with open(html_path, "w") as f:
        f.write(html)
    print(f"HTML saved: {html_path}")
except Exception as e:
    print(f"HTML save failed: {e}")

# 未配置收件人 → 只落盘 HTML，不发送
if not recipients:
    sys.exit(0)

# Send via SES（正文即 HTML，不再生成/附加 PDF）
try:
    ses = boto3.client("ses", region_name=region)
    msg = MIMEMultipart("mixed")
    msg["Subject"] = f"[MeeTap] {title}"
    msg["From"] = sender
    msg["To"] = ", ".join(recipients)

    body = MIMEText(html, "html", "utf-8")
    msg.attach(body)

    ses.send_raw_email(
        Source=sender,
        Destinations=recipients,
        RawMessage={"Data": msg.as_string()}
    )
    print(f"Email sent to: {', '.join(recipients)}")
except Exception as e:
    print(f"Email send failed: {e}")
    sys.exit(1)
PYEOF

    local py_rc=$?
    if [[ -n "$recipients" ]]; then
        if [[ $py_rc -eq 0 ]]; then
            echo "[$(date '+%H:%M:%S')] $(_tn EMAIL_SENT "$recipients")"
        else
            echo "[$(date '+%H:%M:%S')] $(_tn EMAIL_FAILED)"
        fi
    fi
}

# 清洗标题为合法文件名片段：白名单只保留 中文/字母/数字/-/_，其余（含 / : | 空格、
# emoji、控制字符等）一律转 -；连续 - 合并；去首尾 -；按「字符」截断到 20。
# 用 perl -CS 在 UTF-8 字符层面处理，中文算 1 个字符，绝不会截出半个多字节字符。
# 清洗后为空时兜底返回 meeting。
sanitize_title() {
    local raw="$1" cleaned
    cleaned=$(printf '%s' "$raw" | perl -CS -pe '
        s/[^\p{Han}A-Za-z0-9_-]/-/g;   # 白名单外全部替换为 -
        s/-+/-/g;                       # 连续 - 合并
        s/^-+|-+$//g;                   # 去首尾 -
        $_ = substr($_, 0, 20);         # 按字符截断（-CS 下已解码为字符）
        s/-+$//;                        # 截断后可能重新露出尾部 -
    ')
    [[ -z "$cleaned" ]] && cleaned="meeting"
    printf '%s' "$cleaned"
}

# 纪要智能命名：把 meeting-notes.md **重命名**为「YYYY-MM-DD_HHMM_主题.md」
# （mv，不留固定名文件；最终产物只有 <智能命名>.md 与配套 .html）。
# 主题只用 meeting-notes.md 首行 <!-- meetap-title: XXX --> 元数据（Claude 生成），
# 拿不到则兜底 meeting；目录名（含用户 start 时给的会议名）只提供日期时间前缀。
# 标题注释行只要存在就从文件里删掉（它只是元数据，不该进正文/邮件）。
# 最终文件路径写到 stdout 供调用方接住；提示消息走 stderr 避免污染路径输出。
# 任何失败都回退输出原路径，保证调用方始终拿到一个存在的文件。
smart_name_notes() {
    local OUTPUT="$1"
    local SESSION_DIR="$2"
    local SESSION_NAME first_line title="" claude_title=""
    SESSION_NAME=$(basename "$SESSION_DIR")

    # 解析首行元数据；匹配到就删除该注释行（写临时文件后覆盖，避免读写同一文件）
    IFS= read -r first_line < "$OUTPUT" || true
    if [[ "$first_line" == "<!-- meetap-title:"* && "$first_line" == *"-->"* ]]; then
        claude_title="${first_line#<!-- meetap-title:}"
        claude_title="${claude_title%%-->*}"
        # 去首尾空白
        claude_title="${claude_title#"${claude_title%%[![:space:]]*}"}"
        claude_title="${claude_title%"${claude_title##*[![:space:]]}"}"
        local tmp
        tmp=$(mktemp "$SESSION_DIR/.notes.XXXXXX") || { printf '%s' "$OUTPUT"; return 0; }
        tail -n +2 "$OUTPUT" > "$tmp" && mv "$tmp" "$OUTPUT" || { rm -f "$tmp"; printf '%s' "$OUTPUT"; return 0; }
    fi

    # 日期时间前缀从 SESSION_DIR 目录名解析（与 build_prompt 的分支对应）：
    # 标准 20250715_1430[_会议名] → 2025-07-15_1430；非标准格式直接用目录名原样做前缀。
    local prefix
    if [[ "$SESSION_NAME" =~ ^([0-9]{4})([0-9]{2})([0-9]{2})_([0-9]{4})(_(.+))?$ ]]; then
        prefix="${BASH_REMATCH[1]}-${BASH_REMATCH[2]}-${BASH_REMATCH[3]}_${BASH_REMATCH[4]}"
    else
        prefix="$SESSION_NAME"
    fi

    title=$(sanitize_title "$claude_title")

    # 防碰撞：已存在则追加 _2、_3…，绝不静默覆盖
    local target="$SESSION_DIR/${prefix}_${title}.md"
    if [[ -e "$target" ]]; then
        local n=2
        while [[ -e "$SESSION_DIR/${prefix}_${title}_${n}.md" ]]; do ((n++)); done
        target="$SESSION_DIR/${prefix}_${title}_${n}.md"
    fi

    # 末尾补两个空行：Typora 类编辑器打开时光标落在文件末尾，
    # 若末行是落款，其所在行会显示为 Markdown 源码；空行让光标落在空白处
    printf '\n\n' >> "$OUTPUT"
    mv "$OUTPUT" "$target" || { printf '%s' "$OUTPUT"; return 0; }
    echo "[$(date '+%H:%M:%S')] $(_tn NOTES_NAMED "$(basename "$target")")" >&2
    printf '%s' "$target"
}

summarize_transcript() {
    local SESSION_DIR="$1"
    local LOG_DIR="$SESSION_DIR/log"
    local TRANSCRIPT="$LOG_DIR/transcript.txt"
    local OUTPUT="$SESSION_DIR/meeting-notes.md"
    local PROMPT_FILE="$LOG_DIR/.prompt.tmp"

    if [[ ! -f "$TRANSCRIPT" ]]; then
        echo "[$(date '+%H:%M:%S')] $(_tn ERR_TRANSCRIPT_MISSING)"
        return 1
    fi

    echo "[$(date '+%H:%M:%S')] $(_tn GENERATING_NOTES "$CFG_AI_BACKEND")"

    # build_prompt 失败（模板缺失/损坏）时中止：删掉已被截断的空 prompt 文件，
    # 避免把空 prompt 发给 AI 后端浪费一次调用
    if ! build_prompt "$SESSION_DIR" > "$PROMPT_FILE"; then
        rm -f "$PROMPT_FILE"
        return 1
    fi

    case "$CFG_AI_BACKEND" in
        claude-code)
            summarize_via_claude_code "$PROMPT_FILE" "$OUTPUT"
            ;;
        bedrock|*)
            if [[ ! -x "$VENV_PYTHON" ]]; then
                echo "[$(date '+%H:%M:%S')] $(_tn ERR_VENV_MISSING "$VENV_PYTHON")"
                rm -f "$PROMPT_FILE"
                return 1
            fi
            summarize_via_bedrock "$PROMPT_FILE" "$OUTPUT"
            ;;
    esac

    rm -f "$PROMPT_FILE"

    if [[ -f "$OUTPUT" ]]; then
        # smart_name_notes 把 meeting-notes.md 重命名为智能名,返回最终路径
        local FINAL_OUTPUT
        FINAL_OUTPUT=$(smart_name_notes "$OUTPUT" "$SESSION_DIR")
        echo "[$(date '+%H:%M:%S')] $(_tn NOTES_DONE "$FINAL_OUTPUT")"
        osascript -e "display notification \"$(_tn NOTIFY_NOTES_DONE)\" with title \"MeeTap\"" 2>/dev/null
        send_meeting_notes "$FINAL_OUTPUT" "$SESSION_DIR"
    else
        echo "[$(date '+%H:%M:%S')] $(_tn NOTES_FAILED)"
        osascript -e "display notification \"$(_tn NOTIFY_NOTES_FAILED)\" with title \"MeeTap\"" 2>/dev/null
    fi
}

start_recording() {
    local VERBOSE=false
    if [[ "${1:-}" == "-t" || "${1:-}" == "--test" ]]; then
        VERBOSE=true
        echo "true" > "$STATE_DIR/test-mode"
        shift
    else
        rm -f "$STATE_DIR/test-mode"
    fi
    # 可选位置参数：会议名称（meetap start 季度架构评审）
    local MEETING_NAME="${1:-}"

    # 检查是否已在录制
    if [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
        _t ERR_ALREADY_RECORDING "$(cat "$PID_FILE")"
        _t HINT_STOP_FIRST "$0"
        exit 1
    fi
    # 清理残留状态
    rm -f "$PID_FILE" "$MONITOR_PID_FILE"

    # 检查依赖
    if [[ ! -x "$TOOL" ]]; then
        _t ERR_TOOL_MISSING "$TOOL"
        exit 1
    fi
    if [[ ! -x "$MONITOR" ]]; then
        _t ERR_MONITOR_MISSING "$MONITOR"
        exit 1
    fi
    if ! command -v ffmpeg &>/dev/null; then
        _t ERR_FFMPEG_MISSING
        exit 1
    fi

    # --- 音频捕获方式选择 ---
    local TAP_TOOL="$SCRIPT_DIR/audio-tap"
    local use_tap=false
    if [[ "$CFG_AUDIO_CAPTURE" == "tap" ]] || [[ "$CFG_AUDIO_CAPTURE" == "auto" ]]; then
        if [[ -x "$TAP_TOOL" ]] && "$TAP_TOOL" tap-supported &>/dev/null; then
            use_tap=true
        fi
    fi

    # 会话目录 + 录音文件名（两个捕获分支共用，必须在分支前生成）
    local session_base
    session_base="$(date +"%Y%m%d_%H%M")"
    if [[ -n "$MEETING_NAME" ]]; then
        session_base="${session_base}_$(sanitize_title "$MEETING_NAME")"
    fi
    SESSION_DIR="$RECORDING_DIR/$session_base"
    mkdir -p "$SESSION_DIR"
    echo "$SESSION_DIR" > "$STATE_DIR/session-dir"
    TIMESTAMP=$(date +"%Y%m%d_%H%M%S")
    OUTPUT_FILE="$SESSION_DIR/meeting_${TIMESTAMP}.m4a"
    echo "$OUTPUT_FILE" > "$OUTPUT_FILE_MARKER"

    if [[ "$use_tap" == "true" ]]; then
        # --- Process Tap 分支 ---
        # 不切设备、不需要 BlackHole/audio-monitor,用户听到原声
        local TAP_RATE
        TAP_RATE=$("$TAP_TOOL" tap-rate 2>/dev/null || echo 48000)

        ORIG_NAME=$("$TOOL" default-output-name 2>/dev/null || echo "Unknown")
        MIC_NAME=$("$TOOL" default-input-name 2>/dev/null || echo "default")

        # audio-tap tap-start 输出 Float32 LE mono PCM 到 stdout
        # ffmpeg 从 stdin 读系统音 + avfoundation 读麦克风,混录输出
        # 注意1：ffmpeg 的 stdin(pipe:0) 就是 audio-tap 的 PCM 数据管道，
        # 绝不能加 < /dev/null（会覆盖管道 → tap 收 EPIPE 秒退 → 录音全空）。
        # 注意2：avfoundation 自带挂钟时间戳而 pipe 从 0 开始，两路直接 amix
        # 会因时间轴永不对齐而输出 0 字节——必须先 asetpts=PTS-STARTPTS 归零。
        rm -f "$STATE_DIR/tap-level"
        "$TAP_TOOL" tap-start --level-file "$STATE_DIR/tap-level" 2>"$STATE_DIR/tap.log" | \
        ffmpeg -f f32le -ar "$TAP_RATE" -ac 1 -i pipe:0 \
            -f avfoundation -i ":default" \
            -filter_complex "[0:a]asetpts=PTS-STARTPTS[a0];[1:a]asetpts=PTS-STARTPTS[a1];[a0][a1]amix=inputs=2:duration=longest" \
            -c:a aac -b:a "$CFG_AUDIO_BITRATE" -ac 1 \
            -movflags frag_keyframe+empty_moov \
            "$OUTPUT_FILE" \
            > "$STATE_DIR/ffmpeg.log" 2>&1 &

        FFMPEG_PID=$!
        echo $FFMPEG_PID > "$PID_FILE"
        disown $FFMPEG_PID

        sleep 1
        if kill -0 $FFMPEG_PID 2>/dev/null; then
            autostop_daemon &
            AUTOSTOP_PID=$!
            echo $AUTOSTOP_PID > "$AUTOSTOP_PID_FILE"
            disown $AUTOSTOP_PID

            echo ""
            _t RECORDING_STARTED
            $VERBOSE && _t FIELD_FILE "$OUTPUT_FILE"
            _t FIELD_PLAYBACK "$ORIG_NAME (Process Tap)"
            local _grace_display
            if (( CFG_SILENCE_GRACE >= 3600 )); then
                _grace_display="$((CFG_SILENCE_GRACE / 3600)) 小时"
            elif (( CFG_SILENCE_GRACE >= 60 )); then
                _grace_display="$((CFG_SILENCE_GRACE / 60)) 分钟"
            else
                _grace_display="${CFG_SILENCE_GRACE} 秒"
            fi
            _t FIELD_AUTOSTOP "$_grace_display"
            _t FIELD_STOP_CMD "$0"
            echo ""

            # 点阵波形 + 状态栏（与 BlackHole 分支一致；电平来自 tap-level 文件）
            local TTY_DEV
            TTY_DEV=$(tty 2>/dev/null)
            if [[ -n "$TTY_DEV" && "$TTY_DEV" != "not a tty" ]]; then
                sleep 0.1
                setup_statusbar "$TTY_DEV"
                start_visualizer "$TTY_DEV" &
                echo $! > "$VISUALIZER_PID_FILE"
                disown $!
            fi
        else
            _t ERR_FFMPEG_FAIL
            cat "$STATE_DIR/ffmpeg.log"
            exit 1
        fi
    else

    # --- BlackHole 分支(原有逻辑,一字不动) ---
    # 检查 BlackHole
    BH_UID=$("$TOOL" blackhole-uid 2>/dev/null)
    if [[ -z "$BH_UID" ]]; then
        _t ERR_BLACKHOLE_MISSING
        _t HINT_INSTALL_BLACKHOLE
        exit 1
    fi

    # 记住当前输出设备
    ORIG_UID=$("$TOOL" default-output-uid)
    ORIG_NAME=$("$TOOL" default-output-name)

    # 如果当前输出已是 BlackHole，从状态文件恢复真实设备
    if [[ "$ORIG_UID" == "$BH_UID" ]]; then
        if [[ -f "$ORIGINAL_UID_FILE" ]]; then
            ORIG_UID=$(cat "$ORIGINAL_UID_FILE")
            ORIG_NAME=$(cat "$ORIGINAL_NAME_FILE" 2>/dev/null || echo "$ORIG_UID")
            $VERBOSE && _t CUR_OUTPUT_BH "$ORIG_NAME"
        else
            _t ERR_OUTPUT_IS_BH
            exit 1
        fi
    else
        $VERBOSE && _t CUR_OUTPUT "$ORIG_NAME"
    fi

    echo "$ORIG_UID" > "$ORIGINAL_UID_FILE"
    echo "$ORIG_NAME" > "$ORIGINAL_NAME_FILE"

    # 切换系统输出到 BlackHole
    $VERBOSE && _t SWITCHING_TO_BH
    if ! SwitchAudioSource -s "BlackHole 2ch" -t output &>/dev/null; then
        _t ERR_CANT_SWITCH_BH
        exit 1
    fi
    $VERBOSE && _t SWITCHED_TO_BH

    # 启动 audio-monitor：BlackHole → 原始设备（实时转发，用户能听到）
    $VERBOSE && _t STARTING_MONITOR "$ORIG_NAME"
    "$MONITOR" "$BH_UID" "$ORIG_UID" > "$STATE_DIR/monitor.log" 2>&1 &
    MONITOR_PID=$!
    echo $MONITOR_PID > "$MONITOR_PID_FILE"
    disown $MONITOR_PID
    sleep 1

    if ! kill -0 $MONITOR_PID 2>/dev/null; then
        _t ERR_MONITOR_FAIL
        cat "$STATE_DIR/monitor.log"
        SwitchAudioSource -s "$ORIG_NAME" -t output &>/dev/null
        rm -f "$MONITOR_PID_FILE"
        exit 1
    fi
    $VERBOSE && _t MONITOR_STARTED "$ORIG_NAME"

    # 开始录制（系统音频 + 麦克风混录）
    # 会话目录与 OUTPUT_FILE 已在捕获方式分支前生成（两分支共用）
    local MIC_NAME
    MIC_NAME=$("$TOOL" default-input-name 2>/dev/null)
    $VERBOSE && _t MIC_DEVICE "$MIC_NAME"
    ffmpeg -f avfoundation -i ":BlackHole 2ch" \
        -f avfoundation -i ":default" \
        -filter_complex amix=inputs=2:duration=longest \
        -c:a aac -b:a "$CFG_AUDIO_BITRATE" -ac 1 \
        -movflags frag_keyframe+empty_moov \
        "$OUTPUT_FILE" \
        < /dev/null > "$STATE_DIR/ffmpeg.log" 2>&1 &

    FFMPEG_PID=$!
    echo $FFMPEG_PID > "$PID_FILE"
    disown $FFMPEG_PID

    sleep 1
    if kill -0 $FFMPEG_PID 2>/dev/null; then
        # 启动自动停止守护进程（基于音频静音检测）
        autostop_daemon &
        AUTOSTOP_PID=$!
        echo $AUTOSTOP_PID > "$AUTOSTOP_PID_FILE"
        disown $AUTOSTOP_PID

        echo ""
        _t RECORDING_STARTED
        $VERBOSE && _t FIELD_FILE "$OUTPUT_FILE"
        _t FIELD_PLAYBACK "$ORIG_NAME"
        # 格式化 silence_grace 秒数为人类可读(秒/分钟/小时)
        local _grace_display
        if (( CFG_SILENCE_GRACE >= 3600 )); then
            _grace_display="$((CFG_SILENCE_GRACE / 3600)) 小时"
        elif (( CFG_SILENCE_GRACE >= 60 )); then
            _grace_display="$((CFG_SILENCE_GRACE / 60)) 分钟"
        else
            _grace_display="${CFG_SILENCE_GRACE} 秒"
        fi
        _t FIELD_AUTOSTOP "$_grace_display"
        _t FIELD_STOP_CMD "$0"
        echo ""

        local TTY_DEV
        TTY_DEV=$(tty 2>/dev/null)
        if [[ -n "$TTY_DEV" && "$TTY_DEV" != "not a tty" ]]; then
            sleep 0.1
            setup_statusbar "$TTY_DEV"
            start_visualizer "$TTY_DEV" &
            echo $! > "$VISUALIZER_PID_FILE"
            disown $!
        fi
    else
        _t ERR_FFMPEG_FAIL
        cat "$STATE_DIR/ffmpeg.log"
        # 回滚
        kill $MONITOR_PID 2>/dev/null
        SwitchAudioSource -s "$ORIG_NAME" -t output &>/dev/null
        rm -f "$PID_FILE" "$MONITOR_PID_FILE" "$OUTPUT_FILE_MARKER"
        exit 1
    fi

    fi  # 闭合 if use_tap / else (BlackHole 分支结束)
}

stop_recording() {
    local VERBOSE=false
    [[ "${1:-}" == "-t" || "${1:-}" == "--test" ]] && VERBOSE=true
    stop_visualizer

    # 停止自动停止守护进程
    if [[ -f "$AUTOSTOP_PID_FILE" ]]; then
        kill "$(cat "$AUTOSTOP_PID_FILE")" 2>/dev/null
        rm -f "$AUTOSTOP_PID_FILE" "$MEETING_APPS_FILE"
    fi

    if [[ ! -f "$PID_FILE" ]]; then
        _t ERR_NO_ACTIVE_RECORDING
        exit 1
    fi

    FFMPEG_PID=$(cat "$PID_FILE")

    # 停止 ffmpeg
    if kill -0 "$FFMPEG_PID" 2>/dev/null; then
        kill -INT "$FFMPEG_PID"
        _t WAITING_RECORDING
        for i in $(seq 1 15); do
            kill -0 "$FFMPEG_PID" 2>/dev/null || break
            sleep 1
        done
        # 如果 15 秒后仍未退出，强制终止
        if kill -0 "$FFMPEG_PID" 2>/dev/null; then
            _t FFMPEG_FORCE_KILL
            kill -9 "$FFMPEG_PID" 2>/dev/null
            sleep 1
        fi
    fi
    rm -f "$PID_FILE"

    # 停止 audio-monitor
    if [[ -f "$MONITOR_PID_FILE" ]]; then
        MONITOR_PID=$(cat "$MONITOR_PID_FILE")
        kill "$MONITOR_PID" 2>/dev/null
        rm -f "$MONITOR_PID_FILE"
    fi

    # 清理 tap 电平文件（tap 进程随 ffmpeg 退出收 EPIPE 自行退出，无需 kill）
    rm -f "$STATE_DIR/tap-level" "$STATE_DIR/tap-level.tmp"

    # 恢复原始输出设备
    if [[ -f "$ORIGINAL_NAME_FILE" ]]; then
        ORIG_NAME=$(cat "$ORIGINAL_NAME_FILE")
        if SwitchAudioSource -s "$ORIG_NAME" -t output &>/dev/null; then
            _t OUTPUT_RESTORED "$ORIG_NAME"
        elif SwitchAudioSource -s "MacBook Pro Speakers" -t output &>/dev/null; then
            _t ORIG_DEVICE_DISCONNECTED_FALLBACK "$ORIG_NAME"
        else
            _t ORIG_DEVICE_DISCONNECTED_MANUAL "$ORIG_NAME"
        fi
        rm -f "$ORIGINAL_UID_FILE" "$ORIGINAL_NAME_FILE"
    fi

    # 显示文件信息
    if [[ -f "$OUTPUT_FILE_MARKER" ]]; then
        OUTPUT_FILE=$(cat "$OUTPUT_FILE_MARKER")
        rm -f "$OUTPUT_FILE_MARKER"
        if [[ -f "$OUTPUT_FILE" ]]; then
            FILE_SIZE=$(du -h "$OUTPUT_FILE" | cut -f1)
            DURATION=$(ffprobe -v quiet -show_entries format=duration \
                -of csv=p=0 "$OUTPUT_FILE" 2>/dev/null \
                | xargs printf "%.0f" 2>/dev/null)
            if [[ -n "$DURATION" && "$DURATION" -gt 0 ]]; then
                MINS=$((DURATION / 60))
                SECS=$((DURATION % 60))
                if $VERBOSE; then
                    _t RECORDING_SAVED
                    _t FIELD_FILE "$OUTPUT_FILE"
                    _t FIELD_SIZE "$FILE_SIZE"
                    _t FIELD_DURATION "$MINS" "$SECS"
                else
                    _t RECORDING_SUCCESS
                fi
            else
                if $VERBOSE; then
                    _t RECORDING_SAVED
                    _t FIELD_FILE "$OUTPUT_FILE"
                    _t FIELD_SIZE "$FILE_SIZE"
                else
                    _t RECORDING_SUCCESS
                fi
            fi
        fi
    fi

    # 清理空的会话目录，或启动后台转录
    if [[ -f "$STATE_DIR/session-dir" ]]; then
        SESSION_DIR=$(cat "$STATE_DIR/session-dir")
        rm -f "$STATE_DIR/session-dir"
        if [[ -d "$SESSION_DIR" ]] && [ -z "$(ls -A "$SESSION_DIR")" ]; then
            rmdir "$SESSION_DIR"
            _t EMPTY_SESSION_REMOVED "$SESSION_DIR"
        elif [[ -n "$OUTPUT_FILE" && -f "$OUTPUT_FILE" ]]; then
            _t TRANSCRIBE_BACKGROUND
            transcribe_recording "$OUTPUT_FILE" "$SESSION_DIR" &
            disown
        fi
    fi
}

show_status() {
    if [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
        local start_time
        start_time=$(stat -f %m "$PID_FILE" 2>/dev/null)
        local elapsed=""
        if [[ -n "$start_time" ]]; then
            local secs=$(( $(date +%s) - start_time ))
            elapsed=$(printf " (%02d:%02d)" $((secs/60)) $((secs%60)))
        fi
        # 逐行收集状态信息，最后用 ui_card 统一渲染（无 gum 时逐行原样打印）
        local status_lines=()
        status_lines+=("$(_tn STATUS_RECORDING "$elapsed")")
        [[ -f "$OUTPUT_FILE_MARKER" ]] && status_lines+=("$(_tn STATUS_FILE "$(cat "$OUTPUT_FILE_MARKER")")")
        [[ -f "$ORIGINAL_NAME_FILE" ]] && status_lines+=("$(_tn STATUS_PLAYBACK "$(cat "$ORIGINAL_NAME_FILE")")")
        if [[ -f "$AUTOSTOP_PID_FILE" ]] && kill -0 "$(cat "$AUTOSTOP_PID_FILE")" 2>/dev/null; then
            status_lines+=("$(_tn STATUS_AUTOSTOP_ON)")
        fi
        if [[ -f "$MONITOR_PID_FILE" ]] && kill -0 "$(cat "$MONITOR_PID_FILE")" 2>/dev/null; then
            status_lines+=("$(_tn STATUS_MONITOR_RUN)")
        fi
        if [[ -f "$VISUALIZER_PID_FILE" ]] && kill -0 "$(cat "$VISUALIZER_PID_FILE")" 2>/dev/null; then
            status_lines+=("$(_tn STATUS_VISUALIZER_RUN)")
        fi
        ui_card "${status_lines[@]}"
    else
        ui_card "$(_tn STATUS_IDLE)"
        rm -f "$PID_FILE"
    fi
}

setup_zoom() {
    local VIPER_INI="$HOME/Library/Application Support/zoom.us/data/viper.ini"
    local SYSTEM_HEX="53616d652061732053797374656d"  # "Same as System" in hex

    if [[ ! -f "$VIPER_INI" ]]; then
        _t SETUP_ZOOM_NO_CONFIG
        return 1
    fi

    # 检查当前设置
    local CURRENT_SPK
    CURRENT_SPK=$(grep "^AECSPK=" "$VIPER_INI" | cut -d= -f2)
    if [[ "$CURRENT_SPK" == "$SYSTEM_HEX" ]]; then
        _t SETUP_ZOOM_ALREADY_OK
        return 0
    fi

    local CURRENT_NAME
    CURRENT_NAME=$(echo -n "$CURRENT_SPK" | xxd -r -p 2>/dev/null)
    _t SETUP_ZOOM_CUR_SPK "$CURRENT_NAME"

    # Zoom 运行时修改会被覆盖，需要先退出
    if pgrep -x "zoom.us" >/dev/null; then
        _t SETUP_ZOOM_QUITTING
        osascript -e 'tell application "zoom.us" to quit' 2>/dev/null
        # 等待完全退出
        for i in {1..10}; do
            pgrep -x "zoom.us" >/dev/null || break
            sleep 1
        done
        if pgrep -x "zoom.us" >/dev/null; then
            _t SETUP_ZOOM_CANT_QUIT
            return 1
        fi
        local REOPEN_ZOOM=1
    fi

    # 修改扬声器设置
    sed -i '' "s/^AECSPK=.*/AECSPK=$SYSTEM_HEX/" "$VIPER_INI"

    # 同时把「蓝牙通话时的扬声器」也改为跟随系统
    if grep -q "^AECBSSPK=" "$VIPER_INI"; then
        sed -i '' "s/^AECBSSPK=.*/AECBSSPK=$SYSTEM_HEX/" "$VIPER_INI"
    fi

    _t SETUP_ZOOM_DONE

    # 重新打开 Zoom
    if [[ "${REOPEN_ZOOM:-0}" == "1" ]]; then
        _t SETUP_ZOOM_REOPENING
        open -a "zoom.us"
    fi
}

