#!/bin/bash
# MeeTap - macOS 会议录制 + 自动转录工具
VERSION="0.1"

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
TOOL="$SCRIPT_DIR/audio-multi-output"
MONITOR="$SCRIPT_DIR/audio-monitor"
VENV_PYTHON="$SCRIPT_DIR/meetap-venv/bin/python3"
RECORDING_DIR="$HOME/Record"
STATE_DIR="/tmp/meeting-record"

mkdir -p "$RECORDING_DIR" "$STATE_DIR"

# 状态文件
PID_FILE="$STATE_DIR/ffmpeg.pid"
MONITOR_PID_FILE="$STATE_DIR/monitor.pid"
ORIGINAL_UID_FILE="$STATE_DIR/original-output.uid"
ORIGINAL_NAME_FILE="$STATE_DIR/original-output.name"
OUTPUT_FILE_MARKER="$STATE_DIR/output-file"
AUTOSTOP_PID_FILE="$STATE_DIR/autostop.pid"
MEETING_APPS_FILE="$STATE_DIR/meeting-apps"

KNOWN_MEETING_APPS="zoom.us|Microsoft Teams|TencentMeeting|Webex|Lark|Feishu|DingTalk|Slack"

detect_meeting_apps() {
    local found=""
    while IFS= read -r proc; do
        [[ -n "$proc" ]] && found="${found:+$found,}$proc"
    done < <(ps -eo comm= | grep -oE "$KNOWN_MEETING_APPS" | sort -u)
    echo "$found"
}

is_audio_silent() {
    local SAMPLE_DURATION=5
    local SILENCE_THRESHOLD=-50
    local mean_vol
    mean_vol=$(ffmpeg -f avfoundation -i ":BlackHole 2ch" -t "$SAMPLE_DURATION" \
        -af volumedetect -f null /dev/null 2>&1 \
        | grep "mean_volume" | grep -oE '[-0-9.]+' | head -1)
    if [[ -z "$mean_vol" ]]; then
        return 1
    fi
    local vol_int=${mean_vol%%.*}
    [[ $vol_int -le $SILENCE_THRESHOLD ]]
}

autostop_daemon() {
    local CHECK_INTERVAL=30
    local SILENCE_GRACE=120
    local silence_start=""

    while true; do
        if [[ ! -f "$PID_FILE" ]] || ! kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
            break
        fi

        if is_audio_silent; then
            if [[ -z "$silence_start" ]]; then
                silence_start=$(date +%s)
            fi
            local elapsed=$(( $(date +%s) - silence_start ))
            if [[ $elapsed -ge $SILENCE_GRACE ]]; then
                osascript -e "display notification \"持续静音 ${SILENCE_GRACE} 秒，自动停止录制\" with title \"MeeTap\"" 2>/dev/null
                "$0" stop
                break
            fi
        else
            silence_start=""
        fi

        sleep $CHECK_INTERVAL
    done
}

transcribe_recording() {
    local AUDIO_FILE="$1"
    local SESSION_DIR="$2"
    local LOG_FILE="$SESSION_DIR/transcribe.log"
    local AWS_REGION="us-east-1"

    exec > "$LOG_FILE" 2>&1
    echo "[$(date '+%H:%M:%S')] Transcription started"

    if ! command -v aws &>/dev/null; then
        echo "❌ AWS CLI not found, skipping transcription"
        return 1
    fi

    local ACCOUNT_ID
    ACCOUNT_ID=$(aws sts get-caller-identity --query Account --output text 2>/dev/null)
    if [[ -z "$ACCOUNT_ID" ]]; then
        echo "❌ AWS credentials not configured"
        return 1
    fi

    local BUCKET="meetap-transcribe-${ACCOUNT_ID}"
    local AUDIO_BASENAME
    AUDIO_BASENAME=$(basename "$AUDIO_FILE")
    local JOB_NAME="meetap-$(date +%Y%m%d-%H%M%S)-$$"

    # Create bucket if not exists
    aws s3 mb "s3://${BUCKET}" --region "$AWS_REGION" 2>/dev/null || true

    # Upload
    echo "[$(date '+%H:%M:%S')] Uploading audio..."
    if ! aws s3 cp "$AUDIO_FILE" "s3://${BUCKET}/${AUDIO_BASENAME}" --region "$AWS_REGION"; then
        echo "❌ Upload failed"
        return 1
    fi

    # Start transcription
    echo "[$(date '+%H:%M:%S')] Starting transcription job: $JOB_NAME"
    aws transcribe start-transcription-job \
        --transcription-job-name "$JOB_NAME" \
        --identify-language \
        --language-options en-US zh-CN ja-JP \
        --media-format "mp4" \
        --media "{\"MediaFileUri\": \"s3://${BUCKET}/${AUDIO_BASENAME}\"}" \
        --output-bucket-name "$BUCKET" \
        --region "$AWS_REGION" \
        --settings '{"ShowSpeakerLabels": true, "MaxSpeakerLabels": 10}' \
        > /dev/null

    # Poll for completion
    while true; do
        local STATUS
        STATUS=$(aws transcribe get-transcription-job \
            --transcription-job-name "$JOB_NAME" \
            --region "$AWS_REGION" \
            --query 'TranscriptionJob.TranscriptionJobStatus' \
            --output text 2>/dev/null)
        echo "[$(date '+%H:%M:%S')] Status: $STATUS"
        [[ "$STATUS" != "IN_PROGRESS" ]] && break
        sleep 10
    done

    if [[ "$STATUS" != "COMPLETED" ]]; then
        echo "❌ Transcription failed: $STATUS"
        aws s3 rm "s3://${BUCKET}/${AUDIO_BASENAME}" --region "$AWS_REGION" 2>/dev/null
        aws transcribe delete-transcription-job --transcription-job-name "$JOB_NAME" --region "$AWS_REGION" 2>/dev/null
        osascript -e "display notification \"转录失败，请查看日志\" with title \"MeeTap\"" 2>/dev/null
        return 1
    fi

    # Download result
    echo "[$(date '+%H:%M:%S')] Downloading transcript..."
    aws s3 cp "s3://${BUCKET}/${JOB_NAME}.json" "$SESSION_DIR/transcribe-raw.json" --region "$AWS_REGION"

    # Extract transcript with speaker labels
    python3 - "$SESSION_DIR" <<'PYEOF'
import json, sys, os

session_dir = sys.argv[1]
raw_json = os.path.join(session_dir, "transcribe-raw.json")
output_txt = os.path.join(session_dir, "transcript.txt")

with open(raw_json) as f:
    data = json.load(f)

items = data["results"]["items"]
segments = data["results"]["speaker_labels"]["segments"]

time_speaker = {}
for seg in segments:
    for si in seg["items"]:
        time_speaker[si["start_time"]] = si["speaker_label"]

lines = []
current_speaker = None
current_words = []

for item in items:
    if item["type"] == "pronunciation":
        speaker = time_speaker.get(item["start_time"], current_speaker)
        word = item["alternatives"][0]["content"]
        if speaker != current_speaker:
            if current_speaker and current_words:
                lines.append(f"{current_speaker}: {' '.join(current_words)}")
            current_speaker = speaker
            current_words = []
        current_words.append(word)
    elif item["type"] == "punctuation":
        if current_words:
            current_words[-1] += item["alternatives"][0]["content"]

if current_speaker and current_words:
    lines.append(f"{current_speaker}: {' '.join(current_words)}")

with open(output_txt, "w") as f:
    f.write("\n\n".join(lines) + "\n")

print(f"Transcript saved: {len(lines)} speaker turns")
PYEOF

    # Cleanup S3 and Transcribe job
    aws s3 rm "s3://${BUCKET}/${AUDIO_BASENAME}" --region "$AWS_REGION" 2>/dev/null
    aws s3 rm "s3://${BUCKET}/${JOB_NAME}.json" --region "$AWS_REGION" 2>/dev/null
    aws s3 rm "s3://${BUCKET}/.write_access_check_file.temp" --region "$AWS_REGION" 2>/dev/null
    aws transcribe delete-transcription-job --transcription-job-name "$JOB_NAME" --region "$AWS_REGION" 2>/dev/null

    echo "[$(date '+%H:%M:%S')] ✅ Transcription complete: $SESSION_DIR/transcript.txt"
    osascript -e "display notification \"转录完成，正在整理会议纪要...\" with title \"MeeTap\"" 2>/dev/null

    # Generate polished meeting notes via Claude Sonnet 4.6 (Bedrock)
    summarize_transcript "$SESSION_DIR"
}

summarize_transcript() {
    local SESSION_DIR="$1"
    local TRANSCRIPT="$SESSION_DIR/transcript.txt"
    local OUTPUT="$SESSION_DIR/meeting-notes.md"
    local AWS_REGION="us-east-1"
    local MODEL_ID="us.anthropic.claude-sonnet-4-6"

    if [[ ! -f "$TRANSCRIPT" ]]; then
        echo "[$(date '+%H:%M:%S')] ⚠️ transcript.txt not found, skipping summarization"
        return 1
    fi

    if [[ ! -x "$VENV_PYTHON" ]]; then
        echo "[$(date '+%H:%M:%S')] ⚠️ Python venv not found: $VENV_PYTHON, skipping summarization"
        return 1
    fi

    echo "[$(date '+%H:%M:%S')] 📝 Generating meeting notes via Claude Sonnet 4.6 (stream)..."

    local SESSION_NAME
    SESSION_NAME=$(basename "$SESSION_DIR")

    "$VENV_PYTHON" - "$TRANSCRIPT" "$OUTPUT" "$AWS_REGION" "$MODEL_ID" "$SESSION_NAME" <<'PYEOF'
import sys, boto3

transcript_path = sys.argv[1]
output_path = sys.argv[2]
region = sys.argv[3]
model_id = sys.argv[4]
session_name = sys.argv[5]

with open(transcript_path, "r") as f:
    transcript = f.read()

if len(transcript) > 120000:
    transcript = transcript[:120000] + "\n\n[... 内容过长，已截断 ...]"

prompt = f"""你是一位专业的会议纪要整理专家。请将以下会议转录文本整理成一份结构清晰、内容完整的中文会议纪要。

## 要求

1. **保留所有细节、线索和故事线**——不要遗漏任何实质性内容，包括具体的数字、案例、客户名称、技术细节
2. **修正语音识别错误**——根据上下文修正明显的语音转文字错误（如人名、技术术语的拼写）
3. **针对生僻或专业内容，增加扩展注解**——用 `> 📌 注解:` 格式对专业术语、技术概念、行业背景进行简要说明，帮助读者理解
4. **识别发言人**——根据对话内容推断发言人的角色（如主讲人、提问者、补充者），用有意义的标签替代 spk_0/spk_1 等
5. **使用 Markdown 格式**输出，包含标题、分节、要点列表
6. **在末尾生成摘要**——包含会议主题、关键结论、待办事项（如有）

## 输出格式

```markdown
# 会议纪要：[主题]

**日期**：{session_name}
**参会者**：[根据对话推断的角色列表]

---

## 一、[第一个主题]

[整理后的内容，保留所有细节]

> 📌 注解: [对专业术语或背景的补充说明]

## 二、[第二个主题]

...

---

## 会议摘要

- **主题**：
- **关键结论**：
- **待办事项**：
```

## 转录原文

{transcript}"""

try:
    client = boto3.client("bedrock-runtime", region_name=region)
    response = client.converse_stream(
        modelId=model_id,
        messages=[{"role": "user", "content": [{"text": prompt}]}],
        inferenceConfig={"maxTokens": 16000},
    )

    text_parts = []
    for event in response["stream"]:
        if "contentBlockDelta" in event:
            delta = event["contentBlockDelta"]["delta"]
            if "text" in delta:
                text_parts.append(delta["text"])

    text = "".join(text_parts)

    if not text.strip():
        print("Error: empty response from Bedrock")
        sys.exit(1)

    with open(output_path, "w") as f:
        f.write(text)

    print(f"Meeting notes saved: {output_path}")

except Exception as e:
    print(f"Error: {e}")
    sys.exit(1)
PYEOF

    if [[ -f "$OUTPUT" ]]; then
        echo "[$(date '+%H:%M:%S')] ✅ Meeting notes generated: $OUTPUT"
        osascript -e "display notification \"会议纪要已生成: meeting-notes.md\" with title \"MeeTap\"" 2>/dev/null
    else
        echo "[$(date '+%H:%M:%S')] ⚠️ Meeting notes generation failed, transcript.txt is still available"
        osascript -e "display notification \"纪要生成失败，转录文件可用\" with title \"MeeTap\"" 2>/dev/null
    fi
}

start_recording() {
    # 检查是否已在录制
    if [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
        echo "⚠️  已有录制进程在运行 (PID: $(cat "$PID_FILE"))"
        echo "   如需重新开始，请先执行: $0 stop"
        exit 1
    fi
    # 清理残留状态
    rm -f "$PID_FILE" "$MONITOR_PID_FILE"

    # 检查依赖
    if [[ ! -x "$TOOL" ]]; then
        echo "❌ 未找到 audio-multi-output 工具: $TOOL"
        exit 1
    fi
    if [[ ! -x "$MONITOR" ]]; then
        echo "❌ 未找到 audio-monitor 工具: $MONITOR"
        exit 1
    fi
    if ! command -v ffmpeg &>/dev/null; then
        echo "❌ 未找到 ffmpeg，请运行: brew install ffmpeg"
        exit 1
    fi

    # 检查 BlackHole
    BH_UID=$("$TOOL" blackhole-uid 2>/dev/null)
    if [[ -z "$BH_UID" ]]; then
        echo "❌ 未找到 BlackHole 2ch"
        echo "   安装: brew install blackhole-2ch"
        exit 1
    fi

    # 记住当前输出设备
    ORIG_UID=$("$TOOL" default-output-uid)
    ORIG_NAME=$("$TOOL" default-output-name)

    # 如果当前输出已是 BlackHole，从状态文件恢复真实设备
    if [[ "$ORIG_UID" == "$BH_UID" ]]; then
        if [[ -f "$ORIGINAL_UID_FILE" ]]; then
            ORIG_UID=$(cat "$ORIGINAL_UID_FILE")
            ORIG_NAME=$(cat "$ORIGINAL_NAME_FILE" 2>/dev/null || echo "$ORIG_UID")
            echo "📍 当前音频输出: BlackHole (实际设备: $ORIG_NAME)"
        else
            echo "⚠️  当前输出是 BlackHole，请先切回正常扬声器/耳机"
            exit 1
        fi
    else
        echo "📍 当前音频输出: $ORIG_NAME"
    fi

    echo "$ORIG_UID" > "$ORIGINAL_UID_FILE"
    echo "$ORIG_NAME" > "$ORIGINAL_NAME_FILE"

    # 切换系统输出到 BlackHole
    echo "🔧 切换系统输出到 BlackHole 2ch ..."
    if ! SwitchAudioSource -s "BlackHole 2ch" -t output &>/dev/null; then
        echo "❌ 无法切换到 BlackHole"
        exit 1
    fi
    echo "✅ 系统输出已切换到: BlackHole 2ch"

    # 启动 audio-monitor：BlackHole → 原始设备（实时转发，用户能听到）
    echo "🔧 启动音频转发: BlackHole → $ORIG_NAME ..."
    "$MONITOR" "$BH_UID" "$ORIG_UID" > "$STATE_DIR/monitor.log" 2>&1 &
    MONITOR_PID=$!
    echo $MONITOR_PID > "$MONITOR_PID_FILE"
    sleep 1

    if ! kill -0 $MONITOR_PID 2>/dev/null; then
        echo "❌ audio-monitor 启动失败:"
        cat "$STATE_DIR/monitor.log"
        SwitchAudioSource -s "$ORIG_NAME" -t output &>/dev/null
        rm -f "$MONITOR_PID_FILE"
        exit 1
    fi
    echo "✅ 音频转发已启动 → $ORIG_NAME"

    # 创建本次录制的会话目录
    SESSION_DIR="$RECORDING_DIR/$(date +"%m%d_%H%M")"
    mkdir -p "$SESSION_DIR"
    echo "$SESSION_DIR" > "$STATE_DIR/session-dir"

    # 生成录音文件名
    TIMESTAMP=$(date +"%Y%m%d_%H%M%S")
    OUTPUT_FILE="$SESSION_DIR/meeting_${TIMESTAMP}.m4a"
    echo "$OUTPUT_FILE" > "$OUTPUT_FILE_MARKER"

    # 开始录制（系统音频 + 麦克风混录）
    local MIC_NAME
    MIC_NAME=$("$TOOL" default-input-name 2>/dev/null)
    echo "🎤 麦克风: $MIC_NAME"
    ffmpeg -f avfoundation -i ":BlackHole 2ch" \
        -f avfoundation -i ":default" \
        -filter_complex amix=inputs=2:duration=longest \
        -c:a aac -b:a 128k -ac 1 \
        -movflags frag_keyframe+empty_moov \
        "$OUTPUT_FILE" \
        < /dev/null > "$STATE_DIR/ffmpeg.log" 2>&1 &

    FFMPEG_PID=$!
    echo $FFMPEG_PID > "$PID_FILE"

    sleep 1
    if kill -0 $FFMPEG_PID 2>/dev/null; then
        # 启动自动停止守护进程（基于音频静音检测）
        autostop_daemon &
        AUTOSTOP_PID=$!
        echo $AUTOSTOP_PID > "$AUTOSTOP_PID_FILE"
        disown $AUTOSTOP_PID

        echo ""
        echo "🎙️  录制已开始"
        echo "   文件: $OUTPUT_FILE"
        echo "   播放: $ORIG_NAME"
        echo "   自动停止: 持续静音 2 分钟后"
        echo ""
        echo "   停止录制: $0 stop"
    else
        echo "❌ ffmpeg 启动失败:"
        cat "$STATE_DIR/ffmpeg.log"
        # 回滚
        kill $MONITOR_PID 2>/dev/null
        SwitchAudioSource -s "$ORIG_NAME" -t output &>/dev/null
        rm -f "$PID_FILE" "$MONITOR_PID_FILE" "$OUTPUT_FILE_MARKER"
        exit 1
    fi
}

stop_recording() {
    # 停止自动停止守护进程
    if [[ -f "$AUTOSTOP_PID_FILE" ]]; then
        kill "$(cat "$AUTOSTOP_PID_FILE")" 2>/dev/null
        rm -f "$AUTOSTOP_PID_FILE" "$MEETING_APPS_FILE"
    fi

    if [[ ! -f "$PID_FILE" ]]; then
        echo "⚠️  没有正在进行的录制"
        exit 1
    fi

    FFMPEG_PID=$(cat "$PID_FILE")

    # 停止 ffmpeg
    if kill -0 "$FFMPEG_PID" 2>/dev/null; then
        kill -INT "$FFMPEG_PID"
        echo "⏳ 等待录制完成..."
        for i in $(seq 1 15); do
            kill -0 "$FFMPEG_PID" 2>/dev/null || break
            sleep 1
        done
        # 如果 15 秒后仍未退出，强制终止
        if kill -0 "$FFMPEG_PID" 2>/dev/null; then
            echo "⚠️  ffmpeg 未响应 SIGINT，强制终止..."
            kill -9 "$FFMPEG_PID" 2>/dev/null
            sleep 1
        fi
    fi
    rm -f "$PID_FILE"

    # 停止 audio-monitor
    if [[ -f "$MONITOR_PID_FILE" ]]; then
        MONITOR_PID=$(cat "$MONITOR_PID_FILE")
        kill "$MONITOR_PID" 2>/dev/null
        rm -f "$MONITOR_PID_FILE"
    fi

    # 恢复原始输出设备
    if [[ -f "$ORIGINAL_NAME_FILE" ]]; then
        ORIG_NAME=$(cat "$ORIGINAL_NAME_FILE")
        if SwitchAudioSource -s "$ORIG_NAME" -t output &>/dev/null; then
            echo "🔊 音频输出已恢复: $ORIG_NAME"
        else
            echo "⚠️  原始设备 ($ORIG_NAME) 已断开，请手动选择输出设备"
        fi
        rm -f "$ORIGINAL_UID_FILE" "$ORIGINAL_NAME_FILE"
    fi

    # 显示文件信息
    if [[ -f "$OUTPUT_FILE_MARKER" ]]; then
        OUTPUT_FILE=$(cat "$OUTPUT_FILE_MARKER")
        rm -f "$OUTPUT_FILE_MARKER"
        if [[ -f "$OUTPUT_FILE" ]]; then
            FILE_SIZE=$(du -h "$OUTPUT_FILE" | cut -f1)
            DURATION=$(ffprobe -v quiet -show_entries format=duration \
                -of csv=p=0 "$OUTPUT_FILE" 2>/dev/null \
                | xargs printf "%.0f" 2>/dev/null)
            if [[ -n "$DURATION" && "$DURATION" -gt 0 ]]; then
                MINS=$((DURATION / 60))
                SECS=$((DURATION % 60))
                echo ""
                echo "✅ 录制已保存"
                echo "   文件: $OUTPUT_FILE"
                echo "   大小: $FILE_SIZE"
                echo "   时长: ${MINS}分${SECS}秒"
            else
                echo ""
                echo "✅ 录制已保存"
                echo "   文件: $OUTPUT_FILE"
                echo "   大小: $FILE_SIZE"
            fi
        fi
    fi

    # 清理空的会话目录，或启动后台转录
    if [[ -f "$STATE_DIR/session-dir" ]]; then
        SESSION_DIR=$(cat "$STATE_DIR/session-dir")
        rm -f "$STATE_DIR/session-dir"
        if [[ -d "$SESSION_DIR" ]] && [ -z "$(ls -A "$SESSION_DIR")" ]; then
            rmdir "$SESSION_DIR"
            echo "🗑️  未产生录音文件，已删除空目录: $SESSION_DIR"
        elif [[ -n "$OUTPUT_FILE" && -f "$OUTPUT_FILE" ]]; then
            echo ""
            echo "📝 后台转录已启动（完成后会收到通知）"
            transcribe_recording "$OUTPUT_FILE" "$SESSION_DIR" &
            disown
        fi
    fi
}

show_status() {
    if [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
        echo "🎙️  录制中 (PID: $(cat "$PID_FILE"))"
        [[ -f "$OUTPUT_FILE_MARKER" ]] && echo "   文件: $(cat "$OUTPUT_FILE_MARKER")"
        [[ -f "$ORIGINAL_NAME_FILE" ]] && echo "   播放设备: $(cat "$ORIGINAL_NAME_FILE")"
        if [[ -f "$AUTOSTOP_PID_FILE" ]] && kill -0 "$(cat "$AUTOSTOP_PID_FILE")" 2>/dev/null; then
            echo "   自动停止: 已启用 (监控: $(cat "$MEETING_APPS_FILE" 2>/dev/null))"
        fi
        if [[ -f "$MONITOR_PID_FILE" ]] && kill -0 "$(cat "$MONITOR_PID_FILE")" 2>/dev/null; then
            echo "   音频转发: 运行中"
        fi
    else
        echo "⏹️  未在录制"
        rm -f "$PID_FILE"
    fi
}

setup_zoom() {
    local VIPER_INI="$HOME/Library/Application Support/zoom.us/data/viper.ini"
    local SYSTEM_HEX="53616d652061732053797374656d"  # "Same as System" in hex

    if [[ ! -f "$VIPER_INI" ]]; then
        echo "⚠️  未找到 Zoom 配置文件，请先运行一次 Zoom"
        return 1
    fi

    # 检查当前设置
    local CURRENT_SPK
    CURRENT_SPK=$(grep "^AECSPK=" "$VIPER_INI" | cut -d= -f2)
    if [[ "$CURRENT_SPK" == "$SYSTEM_HEX" ]]; then
        echo "✅ Zoom 扬声器已是 Same as System，无需修改"
        return 0
    fi

    local CURRENT_NAME
    CURRENT_NAME=$(echo -n "$CURRENT_SPK" | xxd -r -p 2>/dev/null)
    echo "📍 Zoom 当前扬声器: $CURRENT_NAME"

    # Zoom 运行时修改会被覆盖，需要先退出
    if pgrep -x "zoom.us" >/dev/null; then
        echo "⏳ 正在退出 Zoom（修改后会自动重新打开）..."
        osascript -e 'tell application "zoom.us" to quit' 2>/dev/null
        # 等待完全退出
        for i in {1..10}; do
            pgrep -x "zoom.us" >/dev/null || break
            sleep 1
        done
        if pgrep -x "zoom.us" >/dev/null; then
            echo "❌ Zoom 无法正常退出，请手动关闭后重试"
            return 1
        fi
        local REOPEN_ZOOM=1
    fi

    # 修改扬声器设置
    sed -i '' "s/^AECSPK=.*/AECSPK=$SYSTEM_HEX/" "$VIPER_INI"

    # 同时把「蓝牙通话时的扬声器」也改为跟随系统
    if grep -q "^AECBSSPK=" "$VIPER_INI"; then
        sed -i '' "s/^AECBSSPK=.*/AECBSSPK=$SYSTEM_HEX/" "$VIPER_INI"
    fi

    echo "✅ Zoom 扬声器已设为: Same as System"

    # 重新打开 Zoom
    if [[ "${REOPEN_ZOOM:-0}" == "1" ]]; then
        echo "🔄 正在重新打开 Zoom..."
        open -a "zoom.us"
    fi
}

setup_teams() {
    # 新架构下，录制时系统输出是 BlackHole 2ch。
    # Teams 没有 "System Default" 选项，需要手动选择 BlackHole 2ch 作为扬声器。

    BH_UID=$("$TOOL" blackhole-uid 2>/dev/null)
    if [[ -z "$BH_UID" ]]; then
        echo "❌ 未找到 BlackHole 2ch"
        return 1
    fi

    # 打开 Teams 设备设置页面
    if ! pgrep -f "Microsoft Teams" >/dev/null; then
        echo "⏳ 正在打开 Teams..."
        open -a "Microsoft Teams"
        sleep 3
    fi

    echo "🔧 正在打开 Teams 设备设置..."
    open "msteams://settings/devices" 2>/dev/null

    echo ""
    echo "📋 请在 Teams 设置页面中:"
    echo "   Speaker → 选择「BlackHole 2ch」"
    echo ""
    echo "   ⚠️  只需设置一次"
    echo ""
    read -p "   设置完成后按 Enter 继续..."
    echo "✅ Teams 设置完成"
}

setup_wemeet() {
    # 新架构下，录制时系统输出是 BlackHole 2ch。
    # 腾讯会议需要手动选择 BlackHole 2ch 作为扬声器。

    BH_UID=$("$TOOL" blackhole-uid 2>/dev/null)
    if [[ -z "$BH_UID" ]]; then
        echo "❌ 未找到 BlackHole 2ch"
        return 1
    fi

    # 打开腾讯会议
    if ! pgrep -f "TencentMeeting" >/dev/null; then
        echo "⏳ 正在打开腾讯会议..."
        open -a "TencentMeeting"
        sleep 3
    fi

    echo ""
    echo "📋 请在腾讯会议中手动设置:"
    echo "   1. 点击头像 → 设置 → 音频"
    echo "   2. 扬声器 → 选择「BlackHole 2ch」"
    echo ""
    echo "   ⚠️  只需设置一次"
    echo ""
    read -p "   设置完成后按 Enter 继续..."
    echo "✅ 腾讯会议设置完成"
}

setup_apps() {
    echo "==============================="
    echo " 会议 App 扬声器一键配置"
    echo "==============================="
    echo ""

    echo "【1/3】配置 Zoom"
    echo "---"
    setup_zoom
    echo ""

    echo "【2/3】配置 Teams"
    echo "---"
    setup_teams
    echo ""

    echo "【3/3】配置腾讯会议"
    echo "---"
    setup_wemeet
    echo ""

    echo "==============================="
    echo "✅ 配置完成！现在可以使用 $0 start 录制会议了"
    echo "   此配置只需执行一次，除非你在 App 中手动改回。"
    echo "==============================="
}

case "${1:-}" in
    start)
        start_recording
        ;;
    stop)
        stop_recording
        ;;
    status)
        show_status
        ;;
    setup)
        setup_apps
        ;;
    setup-zoom)
        setup_zoom
        ;;
    setup-teams)
        setup_teams
        ;;
    setup-wemeet)
        setup_wemeet
        ;;
    -v|--version|version)
        echo "MeeTap v${VERSION}"
        ;;
    *)
        echo "MeeTap v${VERSION} - macOS 会议录制 + 自动转录"
        echo ""
        echo "用法: meetap {start|stop|status|setup|version}"
        echo ""
        echo "  start        开始录制（系统音频 + 麦克风）"
        echo "  stop         停止录制，恢复音频设备，自动转录"
        echo "  status       查看当前录制状态"
        echo "  setup        一键配置 Zoom + Teams + 腾讯会议（只需一次）"
        echo "  setup-zoom   仅配置 Zoom"
        echo "  setup-teams  仅配置 Teams"
        echo "  setup-wemeet 仅配置腾讯会议"
        echo "  version      显示版本号"
        echo ""
        echo "首次使用请先运行: meetap setup"
        ;;
esac
