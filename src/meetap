case "${1:-}" in
    start)
        start_recording "${2:-}"
        ;;
    stop)
        stop_recording
        ;;
    status)
        show_status
        ;;
    setup)
        setup_apps
        ;;
    setup-zoom)
        setup_zoom
        ;;
    setup-teams)
        setup_teams
        ;;
    setup-wemeet)
        setup_wemeet
        ;;
    config)
        if [[ "${2:-}" == "init" ]]; then
            config_dir="$(dirname "$CONFIG_FILE")"
            mkdir -p "$config_dir"
            if [[ -f "$CONFIG_FILE" ]]; then
                echo "⚠️  Config file already exists: $CONFIG_FILE"
                echo "   Delete it first and re-run 'meetap config init' to reset"
            else
                cat > "$CONFIG_FILE" <<'CFGEOF'
# MeeTap Configuration
# Uncomment and modify parameters as needed

# ── AWS ──────────────────────────────────────────────────────
# Region (affects S3, Transcribe, Bedrock)
# region = us-east-1

# ── AI / Meeting Notes ───────────────────────────────────────
# Backend for meeting notes generation (bedrock | claude-code)
ai_backend = bedrock
# Bedrock model (only used when ai_backend = bedrock)
# model = us.anthropic.claude-sonnet-4-6

# ── Transcription ────────────────────────────────────────────
# Languages (space-separated, priority order, AWS Transcribe codes)
# Full list: https://docs.aws.amazon.com/transcribe/latest/dg/supported-languages.html
# transcribe_languages = en-US zh-CN ja-JP
# Max speaker labels for speaker diarization (2-10)
# max_speakers = 10
# Enable multi-language detection within a single session (true/false)
# Useful when speakers switch languages; may reduce accuracy for short phrases
# multi_language = false

# ── Recording ────────────────────────────────────────────────
# Output directory
# recording_dir = ~/Record
# Audio bitrate (64k=small file, 128k=balanced, 256k=high quality)
# audio_bitrate = 128k
# Keep local audio file after S3 upload (true=keep, false=delete after upload)
# audio_persist = false

# ── Auto-stop ────────────────────────────────────────────────
# Silence detection threshold (dB)
# silence_threshold = -50
# Stop after N seconds of continuous silence
# silence_grace = 120

# ── Display ──────────────────────────────────────────────────
# CLI display language
# language = zh-CN
# Audio visualizer style: dot | bar | spectrum (color bars) | block
# visualizer = dot
CFGEOF
                echo "✅ Config file created: $CONFIG_FILE"
                echo "   Uncomment and edit to customize"
            fi
        else
            echo "MeeTap v${VERSION} Configuration"
            echo "================================="
            if [[ -f "$CONFIG_FILE" ]]; then
                echo "Config file: $CONFIG_FILE"
            else
                echo "Config file: (not created, using defaults)"
            fi
            echo ""
            echo "  region                = $CFG_REGION"
            echo "  language              = $CFG_LANGUAGE"
            echo "  ai_backend            = $CFG_AI_BACKEND"
            echo "  model                 = $CFG_MODEL"
            echo "  transcribe_languages  = $CFG_TRANSCRIBE_LANGUAGES"
            echo "  recording_dir         = $CFG_RECORDING_DIR"
            echo "  max_speakers          = $CFG_MAX_SPEAKERS"
            echo "  silence_threshold     = $CFG_SILENCE_THRESHOLD"
            echo "  silence_grace         = $CFG_SILENCE_GRACE"
            echo "  audio_bitrate         = $CFG_AUDIO_BITRATE"
            echo "  audio_persist         = $CFG_AUDIO_PERSIST"
            echo "  multi_language        = $CFG_MULTI_LANGUAGE"
            echo "  visualizer            = $CFG_VISUALIZER"
            echo ""
            echo "Run 'meetap config init' to generate config file"
        fi
        ;;
    -v|--version|version)
        echo "MeeTap v${VERSION}"
        ;;
    *)
        echo "MeeTap v${VERSION} - macOS 会议录制 + 自动转录"
        echo ""
        echo "用法: meetap {start|stop|status|setup|config|version}"
        echo ""
        echo "  start [-t]   开始录制（-t 显示详细设备信息）"
        echo "  stop         停止录制，恢复音频设备，自动转录"
        echo "  status       查看当前录制状态"
        echo "  setup        一键配置 Zoom + Teams + 腾讯会议（只需一次）"
        echo "  config       显示当前配置"
        echo "  config init  生成默认配置文件"
        echo "  version      显示版本号"
        echo ""
        echo "首次使用请先运行: meetap setup"
        ;;
esac
