# MeeTap Configuration

# ── AWS ──────────────────────────────────────────────────────
# Region (affects S3, Transcribe, Bedrock)
region = us-east-1

# ── AI / Meeting Notes ───────────────────────────────────────
# Backend for meeting notes generation (bedrock | claude-code)
ai_backend = bedrock
# Bedrock model (only used when ai_backend = bedrock)
model = global.anthropic.claude-sonnet-5

# ── Transcription ────────────────────────────────────────────
# Languages (space-separated, priority order, AWS Transcribe codes)
# Full list: https://docs.aws.amazon.com/transcribe/latest/dg/supported-languages.html
transcribe_languages = en-US zh-CN ja-JP
# Max speaker labels for speaker diarization (2-10)
max_speakers = 10
# Enable multi-language detection within a single session (true/false)
multi_language = false

# ── Recording ────────────────────────────────────────────────
# Output directory
recording_dir = ~/Record
# Audio bitrate (64k=small file, 128k=balanced, 256k=high quality)
audio_bitrate = 128k
# Keep local audio file after S3 upload (true=keep, false=delete after upload)
audio_persist = true
# Audio capture method: auto | tap | blackhole
# auto = use Process Tap if supported (macOS 14.4+), else BlackHole
audio_capture = auto

# ── Auto-stop ────────────────────────────────────────────────
# Silence detection threshold (dB)
silence_threshold = -50
# Stop after N seconds of continuous silence
silence_grace = 120
# Mic gate threshold (dBFS, tap mode only): mic louder than this counts as
# "someone is speaking" — feeds the waveform and resets the silence timer
# (for in-person meetings where system audio stays silent).
# Typical speech: -25~-35 (CoreAudio tap meter); room noise: below -48. Raise if noisy environment
# keeps recording alive; lower if soft speech gets ignored.
mic_threshold = -42

# ── Display ──────────────────────────────────────────────────
# CLI display language (en-US | zh-CN)
# Only affects terminal output, notifications, and help text.
# Meeting notes are always generated in Chinese regardless of this setting;
# transcripts remain in the meeting's original language.
language = zh-CN
# Audio visualizer style: dot | bar | spectrum (color bars) | block
visualizer = dot

# ── Email (optional) ────────────────────────────────────────
# Recipients for meeting notes (comma-separated, leave empty to disable)
# email = alice@example.com, bob@example.com
# SES verified sender address (required if email is set)
# email_sender = meetap@example.com
